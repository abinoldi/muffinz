#!/system/bin/sh

# ==========================================================
# ROBLOX CLONE MANAGER v3.8 (AUTO-MIGRATE DB TO TXT)
# ==========================================================

BACKUP_DIR="/sdcard/RobloxBackups"
DOWNLOAD_DIR="/sdcard/Download/RobloxAPKs"
BASE_URL="http://43.134.116.2:5555/uploaded"

# KONFIGURASI SQLITE & TEMP
TERMUX_SQLITE="/data/data/com.termux/files/usr/bin/sqlite3"
TMP_SQLITE="/data/local/tmp/sqlite3_exec"
TEMP_DB_DIR="/data/local/tmp/rbx_temp_cookies"

# KONFIGURASI TIMEOUT
TIMEOUT_SEC=300

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "❌ Script ini MEMBUTUHKAN akses Root!"
        exit 1
    fi
}

prepare_sqlite() {
    rm -f "$TMP_SQLITE"
    if [ -f "$TERMUX_SQLITE" ]; then
        cp "$TERMUX_SQLITE" "$TMP_SQLITE"
        chmod 755 "$TMP_SQLITE"
        SQLITE_BIN="$TMP_SQLITE"
    else
        SQLITE_BIN=$(which sqlite3)
    fi

    if [ -z "$SQLITE_BIN" ] || [ ! -x "$SQLITE_BIN" ]; then
        echo "❌ sqlite3 tidak ditemukan. Wajib install: pkg install sqlite"
        exit 1
    fi

    rm -rf "$TEMP_DB_DIR"
    mkdir -p "$TEMP_DB_DIR"
    chmod 777 "$TEMP_DB_DIR"
}

# --- FITUR BARU: MIGRASI BACKUP LAMA (.db) ke (.txt) ---
convert_legacy_backups() {
    local old_dbs=($(ls "$BACKUP_DIR"/*.db 2>/dev/null))
    
    if [ ${#old_dbs[@]} -gt 0 ]; then
        echo "------------------------------------------"
        echo "🔄 MENDETEKSI BACKUP LAMA (.db)"
        echo "⚠️ Memulai konversi ke format Universal (.txt)..."
        prepare_sqlite
        
        for db_file in "${old_dbs[@]}"; do
            local base_name=$(basename "$db_file" .db)
            # Ekstrak cookie dari file .db lama
            local cookie_val=$("$SQLITE_BIN" "$db_file" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;" 2>/dev/null)
            
            if [ -n "$cookie_val" ]; then
                echo "$cookie_val" > "$BACKUP_DIR/${base_name}.txt"
                echo "  ✅ Berhasil konversi: ${base_name}.txt"
                # Rename file .db lama menjadi .bak agar tidak terbaca dua kali, tapi tetap aman jika butuh rollback
                mv "$db_file" "${db_file}.bak"
            else
                echo "  ❌ Gagal ekstrak (DB Kosong/Corrupt): $db_file"
                mv "$db_file" "${db_file}.error"
            fi
        done
        echo "✨ Konversi selesai!"
        echo "------------------------------------------"
    fi
}

generate_db_file() {
    local index="$1"
    local raw_cookie="$2"
    local db_path="$TEMP_DB_DIR/cookie_$index.db"

    rm -f "$db_path"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE cookies(creation_utc INTEGER NOT NULL, top_frame_site_key TEXT NOT NULL, host_key TEXT NOT NULL, name TEXT NOT NULL, value TEXT NOT NULL, encrypted_value BLOB DEFAULT '', path TEXT NOT NULL, expires_utc INTEGER NOT NULL, is_secure INTEGER NOT NULL, is_httponly INTEGER NOT NULL, last_access_utc INTEGER NOT NULL, has_expires INTEGER NOT NULL DEFAULT 1, is_persistent INTEGER NOT NULL DEFAULT 1, priority INTEGER NOT NULL DEFAULT 1, samesite INTEGER NOT NULL DEFAULT -1, source_scheme INTEGER NOT NULL DEFAULT 0, source_port INTEGER NOT NULL DEFAULT -1, is_same_party INTEGER NOT NULL DEFAULT 0, UNIQUE (top_frame_site_key, host_key, name, path));"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE meta(key LONGVARCHAR NOT NULL UNIQUE PRIMARY KEY, value LONGVARCHAR);"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('last_compatible_version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO cookies (creation_utc, top_frame_site_key, host_key, name, value, encrypted_value, path, expires_utc, is_secure, is_httponly, last_access_utc, has_expires, is_persistent, priority, samesite, source_scheme, source_port, is_same_party) VALUES ((strftime('%s','now')*1000000), '', '.roblox.com', '.ROBLOSECURITY', '$raw_cookie', '', '/', 253402300799000000, 1, 1, (strftime('%s','now')*1000000), 1, 1, 1, -1, 1, -1, 0);"
}

do_backup() {
    echo "=========================================="
    echo "       MEMULAI PROSES BACKUP (RAW TEXT)... "
    echo "=========================================="
    mkdir -p "$BACKUP_DIR"
    prepare_sqlite
    
    count=0
    for folder in /data/data/com.roblox.clien*; do
        [ -e "$folder" ] || continue
        pkg_name=$(basename "$folder")
        
        cookie_file=""
        [ -f "$folder/app_webview/Default/Cookies" ] && cookie_file="$folder/app_webview/Default/Cookies"
        [ -f "$folder/app_webview/Cookies" ] && cookie_file="$folder/app_webview/Cookies"

        if [ -n "$cookie_file" ]; then
             local cookie_value=$("$SQLITE_BIN" "$cookie_file" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;" 2>/dev/null)
             
             if [ -n "$cookie_value" ]; then
                 echo "$cookie_value" > "$BACKUP_DIR/${pkg_name}.txt"
                 count=$((count + 1))
             fi
        fi
    done
    echo "✅ Backup Selesai! $count akun tersimpan dengan aman."
}

do_restore_sequential() {
    convert_legacy_backups # Panggil konverter sebelum restore
    
    echo ""
    echo "=========================================="
    echo "  RESTORE LINTAS PACKAGE (SEQUENTIAL)     "
    echo "=========================================="
    prepare_sqlite
    
    backups=($(ls "$BACKUP_DIR"/com.roblox.clien*.txt 2>/dev/null))
    pkgs=($(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"))

    total_backups=${#backups[@]}
    if [ "$total_backups" -eq 0 ]; then echo "❌ Tidak ada file backup (.txt)."; return 1; fi

    i=0
    while [ $i -lt $total_backups ] && [ $i -lt ${#pkgs[@]} ]; do
        current_txt="${backups[$i]}"
        current_pkg="${pkgs[$i]}"
        target_dir="/data/data/$current_pkg/app_webview/Default"
        
        local raw_cookie=$(cat "$current_txt")
        
        generate_db_file "seq_$i" "$raw_cookie"
        local source_db="$TEMP_DB_DIR/cookie_seq_$i.db"
        
        echo "🔄 Restore ke: $current_pkg"
        mkdir -p "$target_dir"
        cp "$source_db" "$target_dir/Cookies"
        
        uid=$(stat -c "%u" "/data/data/$current_pkg")
        chown -R "$uid:$uid" "/data/data/$current_pkg/app_webview"
        chmod 660 "$target_dir/Cookies"
        
        i=$((i + 1))
    done
    
    rm -rf "$TEMP_DB_DIR"
    echo "✅ Restore Selesai."
}

do_uninstall() {
    echo "🗑️ Menghapus aplikasi..."
    for pkg in $(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"); do
        pm uninstall "$pkg" > /dev/null 2>&1
    done
    echo "✅ Bersih."
}

do_auto_process() {
    echo "=========================================="
    echo "   🚀 PROSES OTOMATIS (BACKUP -> INSTALL) "
    echo "=========================================="
    
    convert_legacy_backups # Pastikan file lama dikonversi dulu
    
    total_files=$(ls "$BACKUP_DIR"/com.roblox.clien*.txt 2>/dev/null | wc -l)
    if [ "$total_files" -eq 0 ]; then echo "❌ Tidak ada backup file .txt."; return; fi

    rm -rf "$DOWNLOAD_DIR"
    mkdir -p "$DOWNLOAD_DIR"

    echo "📡 Mendeteksi $total_files backup. Mulai download..."
    
    for i in $(seq 1 "$total_files"); do
        APK_NAME="$i.apk"
        SAVE_PATH="$DOWNLOAD_DIR/$APK_NAME"
        echo -n "⬇️  [$i/$total_files] Download $APK_NAME... "
        curl -L -f --retry 3 --retry-delay 2 -m $TIMEOUT_SEC "$BASE_URL/$APK_NAME" -o "$SAVE_PATH"
        if [ $? -eq 0 ]; then echo " ✅ OK"; else echo " ❌ GAGAL"; fi
    done

    echo "📦 Menginstall..."
    for i in $(seq 1 "$total_files"); do
        APK_NAME="$i.apk"
        SAVE_PATH="$DOWNLOAD_DIR/$APK_NAME"
        if [ -f "$SAVE_PATH" ] && [ $(stat -c%s "$SAVE_PATH") -gt 1000 ]; then
            pm install -r "$SAVE_PATH" > /dev/null 2>&1
        fi
    done

    do_restore_sequential
    echo "✨ SELESAI!"
}

do_download_install_only() {
    echo "=========================================="
    echo "   📥 DOWNLOAD & INSTALL SAJA (NO RESTORE) "
    echo "=========================================="
    echo "⚠️  Fitur ini akan mendownload APK dari 1.apk s/d N.apk"
    echo -n "🔢 Masukkan jumlah clone yang mau diinstall: "
    read target_qty

    if ! [ "$target_qty" -eq "$target_qty" ] 2>/dev/null; then
        echo "❌ Input harus berupa angka!"
        return
    fi

    rm -rf "$DOWNLOAD_DIR"
    mkdir -p "$DOWNLOAD_DIR"

    echo "------------------------------------------"
    echo "📡 Target: $target_qty Aplikasi"
    
    for i in $(seq 1 "$target_qty"); do
        APK_NAME="$i.apk"
        SAVE_PATH="$DOWNLOAD_DIR/$APK_NAME"
        
        echo -n "⬇️  [$i/$target_qty] Mendownload $APK_NAME... "
        curl -L -f --retry 3 --retry-delay 2 -m $TIMEOUT_SEC "$BASE_URL/$APK_NAME" -o "$SAVE_PATH"
        
        if [ $? -eq 0 ]; then echo " ✅ Sukses."; else echo " ❌ GAGAL! (Skip)"; fi
    done

    echo "------------------------------------------"
    echo "📦 [PHASE 2] Menginstall Aplikasi..."
    
    installed_count=0
    for i in $(seq 1 "$target_qty"); do
        APK_NAME="$i.apk"
        SAVE_PATH="$DOWNLOAD_DIR/$APK_NAME"
        
        if [ -f "$SAVE_PATH" ] && [ $(stat -c%s "$SAVE_PATH") -gt 1000 ]; then
            echo "   💿 Menginstall $APK_NAME..."
            pm install -r "$SAVE_PATH" > /dev/null 2>&1
            installed_count=$((installed_count + 1))
        fi
    done

    echo "✨ SELESAI! ($installed_count berhasil diinstall tanpa restore)"
}

# --- MAIN MENU ---
check_root
while true; do
    echo ""
    echo "=========================================="
    echo "    ROBLOX MANAGER v3.8 (AUTO-MIGRATE)    "
    echo "=========================================="
    echo "1. Backup Akun (Format Universal .txt)"
    echo "2. Restore Akun (Otomatis Build DB & Migrasi Lama)"
    echo "3. Hapus Semua Aplikasi"
    echo "4. AUTO PROCESS (Download + Install + Restore)"
    echo "5. DOWNLOAD & INSTALL SAJA (No Restore)"
    echo "6. Keluar"
    echo -n "Pilih: "
    read choice
    case $choice in
        1) do_backup ;;
        2) do_restore_sequential ;;
        3) do_uninstall ;;
        4) do_auto_process ;;
        5) do_download_install_only ;;
        6) rm -rf "$TEMP_DB_DIR"; exit 0 ;;
        *) echo "⚠️ Salah." ;;
    esac
done
