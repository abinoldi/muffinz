#!/system/bin/sh

# ==========================================================
# ROBLOX INJECTOR v11.0 (BACKUP, RESTORE & VALIDATOR)
# ==========================================================

TERMUX_SQLITE="/data/data/com.termux/files/usr/bin/sqlite3"
TMP_SQLITE="/data/local/tmp/sqlite3_exec"
TEMP_DB_DIR="/data/local/tmp/rbx_temp_cookies"
COOKIE_QUEUE="/data/local/tmp/rbx_queue.txt"
BACKUP_DIR="/sdcard/RobloxBackups"

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "❌ Script ini MEMBUTUHKAN akses Root!"
        exit 1
    fi
}

prepare_env() {
    if ! command -v curl >/dev/null 2>&1; then
        echo "❌ Curl tidak ditemukan. Install dulu: pkg install curl"
        exit 1
    fi

    rm -f "$TMP_SQLITE"
    if [ -f "$TERMUX_SQLITE" ]; then
        cp "$TERMUX_SQLITE" "$TMP_SQLITE"
        chmod 755 "$TMP_SQLITE"
        SQLITE_BIN="$TMP_SQLITE"
    else
        SQLITE_BIN=$(which sqlite3)
    fi

    if [ -z "$SQLITE_BIN" ] || [ ! -x "$SQLITE_BIN" ]; then
        echo "❌ sqlite3 tidak ditemukan. Wajib install: pkg install sqlite"
        exit 1
    fi

    rm -rf "$TEMP_DB_DIR"
    mkdir -p "$TEMP_DB_DIR"
    mkdir -p "$BACKUP_DIR"
    chmod 777 "$TEMP_DB_DIR"
}

check_existing_cookie() {
    local pkg="$1"
    local db_path="/data/data/$pkg/app_webview/Default/Cookies"
    
    if [ ! -f "$db_path" ]; then return 1; fi

    local cookie_value=$("$SQLITE_BIN" "$db_path" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;" 2>/dev/null)
    
    if [ -n "$cookie_value" ]; then
        return 0 # Sudah login
    else
        return 1 # Kosong
    fi
}

validate_cookie_online() {
    local cookie_val="$1"
    echo -n "   ⏳ Mengecek validitas... "
    response=$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 \
        -H "Cookie: .ROBLOSECURITY=$cookie_val" \
        "https://users.roblox.com/v1/users/authenticated")

    if [ "$response" -eq 200 ]; then
        echo "✅ VALID (Live)"
        return 0
    else
        echo "❌ MATI/INVALID ($response)"
        return 1
    fi
}

generate_db_file() {
    local index="$1"
    local raw_cookie="$2"
    local db_path="$TEMP_DB_DIR/cookie_$index.db"

    rm -f "$db_path"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE cookies(creation_utc INTEGER NOT NULL, top_frame_site_key TEXT NOT NULL, host_key TEXT NOT NULL, name TEXT NOT NULL, value TEXT NOT NULL, encrypted_value BLOB DEFAULT '', path TEXT NOT NULL, expires_utc INTEGER NOT NULL, is_secure INTEGER NOT NULL, is_httponly INTEGER NOT NULL, last_access_utc INTEGER NOT NULL, has_expires INTEGER NOT NULL DEFAULT 1, is_persistent INTEGER NOT NULL DEFAULT 1, priority INTEGER NOT NULL DEFAULT 1, samesite INTEGER NOT NULL DEFAULT -1, source_scheme INTEGER NOT NULL DEFAULT 0, source_port INTEGER NOT NULL DEFAULT -1, is_same_party INTEGER NOT NULL DEFAULT 0, UNIQUE (top_frame_site_key, host_key, name, path));"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE meta(key LONGVARCHAR NOT NULL UNIQUE PRIMARY KEY, value LONGVARCHAR);"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('last_compatible_version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO cookies (creation_utc, top_frame_site_key, host_key, name, value, encrypted_value, path, expires_utc, is_secure, is_httponly, last_access_utc, has_expires, is_persistent, priority, samesite, source_scheme, source_port, is_same_party) VALUES ((strftime('%s','now')*1000000), '', '.roblox.com', '.ROBLOSECURITY', '$raw_cookie', '', '/', 253402300799000000, 1, 1, (strftime('%s','now')*1000000), 1, 1, 1, -1, 1, -1, 0);"
}

restore_db() {
    local pkg_name="$1"
    local source_db="$2"
    local target_root="/data/data/$pkg_name"
    local target_folder="$target_root/app_webview/Default"
    local target_file="$target_folder/Cookies"

    echo "   🔄 Injecting: $pkg_name"
    am force-stop "$pkg_name" > /dev/null 2>&1

    if [ -e "$target_file" ]; then rm -f "$target_file"; fi
    if [ -d "$target_file" ]; then rm -rf "$target_file"; fi

    if [ ! -d "$target_folder" ]; then
        mkdir -p "$target_folder"
        local uid_awal=$(stat -c "%u:%g" "$target_root")
        chown -R "$uid_awal" "$target_root/app_webview"
    fi

    cp "$source_db" "$target_file"
    local app_uid=$(stat -c "%u:%g" "$target_root")
    chown -R "$app_uid" "$target_root/app_webview"
    chmod 660 "$target_file"
}

# --- FITUR BARU: BACKUP ---
backup_cookies() {
    echo "------------------------------------------"
    echo "💾 MENCARI APLIKASI UNTUK DI-BACKUP..."
    echo "------------------------------------------"
    
    raw_pkgs=($(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"))
    local found=0
    
    for pkg in "${raw_pkgs[@]}"; do
        local db_path="/data/data/$pkg/app_webview/Default/Cookies"
        if [ -f "$db_path" ]; then
            local cookie_value=$("$SQLITE_BIN" "$db_path" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;" 2>/dev/null)
            if [ -n "$cookie_value" ]; then
                # Simpan RAW Cookie ke SDCard
                local timestamp=$(date +"%Y%m%d_%H%M%S")
                local backup_file="$BACKUP_DIR/${pkg}_${timestamp}.txt"
                echo "$cookie_value" > "$backup_file"
                echo "✅ Tersimpan: ${pkg}_${timestamp}.txt"
                found=1
            fi
        fi
    done

    if [ $found -eq 0 ]; then
        echo "❌ Tidak ada aplikasi Roblox yang sedang login."
    else
        echo "📂 Semua backup tersimpan di: $BACKUP_DIR"
    fi
}

# --- FITUR BARU: RESTORE ---
restore_cookies() {
    echo "------------------------------------------"
    echo "🔄 RESTORE COOKIES KE APLIKASI"
    echo "------------------------------------------"
    
    if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]; then
        echo "❌ Tidak ada file backup di $BACKUP_DIR"
        return
    fi

    # 1. Pilih File Backup
    echo "📂 File Backup Tersedia:"
    backups=($(ls "$BACKUP_DIR" | grep ".txt"))
    for i in "${!backups[@]}"; do
        echo "  $((i+1)). ${backups[$i]}"
    done
    
    echo -n "👉 Pilih nomor backup (0 untuk batal): "
    read b_idx
    if [ "$b_idx" -eq 0 ]; then return; fi
    b_idx=$((b_idx-1))
    
    local selected_backup="${backups[$b_idx]}"
    if [ -z "$selected_backup" ]; then echo "❌ Pilihan tidak valid."; return; fi
    local saved_cookie=$(cat "$BACKUP_DIR/$selected_backup")

    # 2. Pilih Aplikasi Tujuan
    echo ""
    echo "🎯 Aplikasi Tujuan (Roblox Clones):"
    target_pkgs=($(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"))
    for i in "${!target_pkgs[@]}"; do
        echo "  $((i+1)). ${target_pkgs[$i]}"
    done
    
    echo -n "👉 Pilih nomor target (0 untuk batal): "
    read t_idx
    if [ "$t_idx" -eq 0 ]; then return; fi
    t_idx=$((t_idx-1))
    
    local target_app="${target_pkgs[$t_idx]}"
    if [ -z "$target_app" ]; then echo "❌ Pilihan tidak valid."; return; fi

    # 3. Validasi & Eksekusi Restore
    echo ""
    if validate_cookie_online "$saved_cookie"; then
        generate_db_file "restore" "$saved_cookie"
        restore_db "$target_app" "$TEMP_DB_DIR/cookie_restore.db"
        echo "✨ Restore ke $target_app BERHASIL!"
    else
        echo "❌ Cookie dalam backup ini sudah expired/invalid."
    fi
}

# --- FITUR LAMA: MANUAL INJECT ---
inject_manual() {
    echo "------------------------------------------"
    echo "💉 INJECT MANUAL KOTAK KOSONG"
    echo "------------------------------------------"
    raw_pkgs=($(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"))
    
    if [ ${#raw_pkgs[@]} -eq 0 ]; then
        echo "❌ Tidak ada aplikasi Roblox Clone."
        return
    fi

    echo "🔍 Memfilter aplikasi yang belum login..."
    target_pkgs=()

    for pkg in "${raw_pkgs[@]}"; do
        if check_existing_cookie "$pkg"; then
            echo "   ⏩ SKIP: $pkg (Sudah Login)"
        else
            echo "   🎯 TARGET: $pkg (Kosong)"
            target_pkgs+=("$pkg")
        fi
    done

    total_targets=${#target_pkgs[@]}
    if [ $total_targets -eq 0 ]; then
        echo "✅ Semua aplikasi sudah terisi. Kembali ke menu."
        return
    fi

    echo "📝 Terdapat $total_targets slot kosong. (Ketik 'done' untuk batal)"
    rm -f "$COOKIE_QUEUE"
    
    i=0
    while [ $i -lt $total_targets ]; do
        current_target_pkg="${target_pkgs[$i]}"
        
        while true; do
            echo ""
            echo "👉 [$((i+1))/$total_targets] Target: ...${current_target_pkg: -15}"
            echo -n "   Paste Cookie: "
            read -r input_cookie

            if [ "$input_cookie" = "done" ]; then 
                echo "⚠️  Pengisian dihentikan."
                break 2 
            fi

            if [ -z "$input_cookie" ]; then continue; fi

            if validate_cookie_online "$input_cookie"; then
                echo "$input_cookie" >> "$COOKIE_QUEUE"
                i=$((i + 1))
                break 
            else
                echo "   ⚠️  Silakan ambil cookie baru dan paste ulang."
            fi
        done
    done
    
    if [ ! -f "$COOKIE_QUEUE" ]; then return; fi

    echo "🚀 Memproses Injeksi..."
    idx=0
    while read -r valid_cookie; do
        if [ $idx -ge ${#target_pkgs[@]} ]; then break; fi
        generate_db_file "$((idx+1))" "$valid_cookie"
        restore_db "${target_pkgs[$idx]}" "$TEMP_DB_DIR/cookie_$((idx+1)).db"
        idx=$((idx + 1))
    done < "$COOKIE_QUEUE"

    rm -f "$COOKIE_QUEUE"
    echo "✨ INJEKSI MANUAL SELESAI!"
}

# ==========================================================
# MAIN MENU
# ==========================================================
check_root
prepare_env

while true; do
    echo ""
    echo "=========================================="
    echo "   ROBLOX INJECTOR v11 (BACKUP & RESTORE) "
    echo "=========================================="
    echo " 1. 💉 Inject Manual (Ke aplikasi kosong)"
    echo " 2. 💾 Backup Cookies (Dari semua aplikasi)"
    echo " 3. 🔄 Restore Cookies (Pilih target bebas)"
    echo " 0. ❌ Keluar"
    echo "=========================================="
    echo -n "Pilih Menu [0-3]: "
    read menu_choice

    case $menu_choice in
        1) inject_manual ;;
        2) backup_cookies ;;
        3) restore_cookies ;;
        0) echo "👋 Keluar..."; rm -rf "$TEMP_DB_DIR"; exit 0 ;;
        *) echo "❌ Pilihan tidak valid!" ;;
    esac
done
