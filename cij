#!/system/bin/sh

# ==========================================================
# ROBLOX INJECTOR v10.2 (REFRESH IP + DELAY EDITION)
# ==========================================================

TERMUX_SQLITE="/data/data/com.termux/files/usr/bin/sqlite3"
TMP_SQLITE="/data/local/tmp/sqlite3_exec"
TEMP_DB_DIR="/data/local/tmp/rbx_temp_cookies"
COOKIE_QUEUE="/data/local/tmp/rbx_queue.txt"

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "❌ Script ini MEMBUTUHKAN akses Root!"
        exit 1
    fi
}

prepare_env() {
    if ! command -v curl >/dev/null 2>&1; then
        echo "❌ Curl tidak ditemukan. Install dulu: pkg install curl"
        exit 1
    fi

    rm -f "$TMP_SQLITE"
    if [ -f "$TERMUX_SQLITE" ]; then
        cp "$TERMUX_SQLITE" "$TMP_SQLITE"
        chmod 755 "$TMP_SQLITE"
        SQLITE_BIN="$TMP_SQLITE"
    else
        SQLITE_BIN=$(which sqlite3)
    fi

    if [ -z "$SQLITE_BIN" ] || [ ! -x "$SQLITE_BIN" ]; then
        echo "❌ sqlite3 tidak ditemukan. Wajib install: pkg install sqlite"
        exit 1
    fi

    rm -rf "$TEMP_DB_DIR"
    mkdir -p "$TEMP_DB_DIR"
    chmod 777 "$TEMP_DB_DIR"
}

check_existing_cookie() {
    local pkg="$1"
    local db_path="/data/data/$pkg/app_webview/Default/Cookies"
    
    if [ ! -f "$db_path" ]; then return 1; fi

    local cookie_value=$("$SQLITE_BIN" "$db_path" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;" 2>/dev/null)
    
    if [ -n "$cookie_value" ]; then
        return 0 
    else
        return 1 
    fi
}

validate_cookie_online() {
    local cookie_val="$1"
    
    echo -n "   ⏳ Mengecek validitas... "
    
    response=$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 \
        -H "Cookie: .ROBLOSECURITY=$cookie_val" \
        "https://users.roblox.com/v1/users/authenticated")

    if [ "$response" -eq 200 ]; then
        echo "✅ VALID (Live)"
        return 0
    else
        echo "❌ MATI/INVALID ($response)"
        return 1
    fi
}

# --- FUNGSI BARU: REFRESH COOKIE (EKSTRAKSI JAR 100% AKURAT) ---
refresh_cookie() {
    local old_cookie="$1"
    local UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
    
    # Membuat ID unik untuk file sementara agar tidak tabrakan antar akun
    local unique_id="$$_${RANDOM}_$(date +%s)"
    local COOKIE_JAR="$TEMP_DB_DIR/jar_${unique_id}.txt"
    local HEADER_DUMP="$TEMP_DB_DIR/headers_${unique_id}.txt"

    # 1. Dapatkan X-CSRF-TOKEN (Simpan header ke file)
    curl -s -D "$HEADER_DUMP" -X POST "https://auth.roblox.com/v2/logout" \
        -H "Cookie: .ROBLOSECURITY=$old_cookie" \
        -H "User-Agent: $UA" \
        -H "Origin: https://www.roblox.com" \
        -H "Referer: https://www.roblox.com/" \
        -H "Content-Length: 0" \
        -c "$COOKIE_JAR" -o /dev/null

    local csrf_token=$(grep -i 'x-csrf-token:' "$HEADER_DUMP" | awk '{print $2}' | tr -d '\r\n')

    if [ -z "$csrf_token" ]; then
        echo "FAIL_CSRF"
        rm -f "$COOKIE_JAR" "$HEADER_DUMP"
        return 1
    fi

    # 2. Dapatkan Authentication Ticket
    curl -s -D "$HEADER_DUMP" -X POST "https://auth.roblox.com/v1/authentication-ticket" \
        -H "Cookie: .ROBLOSECURITY=$old_cookie" \
        -H "x-csrf-token: $csrf_token" \
        -H "User-Agent: $UA" \
        -H "Origin: https://www.roblox.com" \
        -H "Referer: https://www.roblox.com/" \
        -H "Content-Type: application/json" \
        -b "$COOKIE_JAR" -c "$COOKIE_JAR" -o /dev/null
        
    local auth_ticket=$(grep -i 'rbx-authentication-ticket:' "$HEADER_DUMP" | awk '{print $2}' | tr -d '\r\n')

    if [ -z "$auth_ticket" ]; then
        local http_status=$(head -n 1 "$HEADER_DUMP" | tr -d '\r\n')
        echo "FAIL_TICKET ($http_status)"
        rm -f "$COOKIE_JAR" "$HEADER_DUMP"
        return 1
    fi

    # Beri nafas untuk backend Roblox memproses tiket
    sleep 2

    # 3. Redeem Ticket
    curl -s -D "$HEADER_DUMP" -X POST "https://auth.roblox.com/v1/authentication-ticket/redeem" \
        -H "RBXAuthenticationNegotiation: 1" \
        -H "User-Agent: $UA" \
        -H "Origin: https://www.roblox.com" \
        -H "Referer: https://www.roblox.com/" \
        -H "Content-Type: application/json" \
        -b "$COOKIE_JAR" -c "$COOKIE_JAR" \
        -d "{\"authenticationTicket\": \"$auth_ticket\"}" -o /dev/null

    # EKSTRAKSI BARU: Ambil cookie dari file Cookie Jar yang disusun rapi oleh cURL
    local new_cookie=""
    if [ -f "$COOKIE_JAR" ]; then
        # cut -f7 mengambil kolom ke-7 (kolom value) dari format standar Netscape Cookie
        new_cookie=$(grep '.ROBLOSECURITY' "$COOKIE_JAR" | cut -f7 | tr -d '\r\n')
    fi

    # Jika berhasil ditemukan cookie-nya
    if [ -n "$new_cookie" ]; then
        echo "$new_cookie"
        rm -f "$COOKIE_JAR" "$HEADER_DUMP"
        return 0
    else
        # Jika gagal, tampilkan status HTTP terakhir
        local http_status2=$(head -n 1 "$HEADER_DUMP" | tr -d '\r\n')
        echo "FAIL_EKSTRAK ($http_status2)"
        rm -f "$COOKIE_JAR" "$HEADER_DUMP"
        return 1
    fi
}

generate_db_file() {
    local index="$1"
    local raw_cookie="$2"
    local db_path="$TEMP_DB_DIR/cookie_$index.db"

    rm -f "$db_path"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE cookies(creation_utc INTEGER NOT NULL, top_frame_site_key TEXT NOT NULL, host_key TEXT NOT NULL, name TEXT NOT NULL, value TEXT NOT NULL, encrypted_value BLOB DEFAULT '', path TEXT NOT NULL, expires_utc INTEGER NOT NULL, is_secure INTEGER NOT NULL, is_httponly INTEGER NOT NULL, last_access_utc INTEGER NOT NULL, has_expires INTEGER NOT NULL DEFAULT 1, is_persistent INTEGER NOT NULL DEFAULT 1, priority INTEGER NOT NULL DEFAULT 1, samesite INTEGER NOT NULL DEFAULT -1, source_scheme INTEGER NOT NULL DEFAULT 0, source_port INTEGER NOT NULL DEFAULT -1, is_same_party INTEGER NOT NULL DEFAULT 0, UNIQUE (top_frame_site_key, host_key, name, path));"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE meta(key LONGVARCHAR NOT NULL UNIQUE PRIMARY KEY, value LONGVARCHAR);"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('last_compatible_version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO cookies (creation_utc, top_frame_site_key, host_key, name, value, encrypted_value, path, expires_utc, is_secure, is_httponly, last_access_utc, has_expires, is_persistent, priority, samesite, source_scheme, source_port, is_same_party) VALUES ((strftime('%s','now')*1000000), '', '.roblox.com', '.ROBLOSECURITY', '$raw_cookie', '', '/', 253402300799000000, 1, 1, (strftime('%s','now')*1000000), 1, 1, 1, -1, 1, -1, 0);"
}

restore_db() {
    local pkg_name="$1"
    local source_db="$2"
    local target_root="/data/data/$pkg_name"
    local target_folder="$target_root/app_webview/Default"
    local target_file="$target_folder/Cookies"

    echo "   📥 Injecting ke: $pkg_name"
    am force-stop "$pkg_name" > /dev/null 2>&1

    if [ -e "$target_file" ]; then rm -f "$target_file"; fi
    if [ -d "$target_file" ]; then rm -rf "$target_file"; fi

    if [ ! -d "$target_folder" ]; then
        mkdir -p "$target_folder"
        local uid_awal=$(stat -c "%u:%g" "$target_root")
        chown -R "$uid_awal" "$target_root/app_webview"
    fi

    cp "$source_db" "$target_file"
    local app_uid=$(stat -c "%u:%g" "$target_root")
    chown -R "$app_uid" "$target_root/app_webview"
    chmod 660 "$target_file"
}

do_main_process() {
    echo "=========================================="
    echo " ROBLOX INJECTOR v10.2 (REFRESH & DELAY) "
    echo "=========================================="
    prepare_env
    
    raw_pkgs=($(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"))
    
    if [ ${#raw_pkgs[@]} -eq 0 ]; then
        echo "❌ Tidak ada aplikasi Roblox Clone."
        return
    fi

    echo "🔍 Memeriksa status login & menyiapkan target..."
    target_pkgs=()

    for pkg in "${raw_pkgs[@]}"; do
        if check_existing_cookie "$pkg"; then
            echo "   ⚠️ TARGET: $pkg (Sudah Login -> AKAN DITIMPA)"
        else
            echo "   🎯 TARGET: $pkg (Kosong -> Perlu Injeksi)"
        fi
        target_pkgs+=("$pkg")
    done

    total_targets=${#target_pkgs[@]}

    if [ $total_targets -eq 0 ]; then
        echo "✅ Tidak ada target yang bisa diproses. Keluar."
        rm -rf "$TEMP_DB_DIR"
        exit 0
    fi

    echo "------------------------------------------"
    echo "📝 TAHAP 1: INPUT COOKIE"
    echo "   (Mengisi slot ke dalam antrean)"
    echo "------------------------------------------"
    
    rm -f "$COOKIE_QUEUE"
    
    i=0
    while [ $i -lt $total_targets ]; do
        display_num=$((i + 1))
        current_target_pkg="${target_pkgs[$i]}"
        
        while true; do
            echo ""
            echo "👉 [$display_num/$total_targets] Target: ...${current_target_pkg: -15}"
            echo -n "   Paste Cookie (atau ketik 'done'): "
            read -r input_cookie

            if [ "$input_cookie" = "done" ]; then 
                echo "⚠️  Input dihentikan oleh user. Melanjutkan ke proses Eksekusi..."
                break 2 
            fi

            if [ -z "$input_cookie" ]; then
                echo "   ❌ Cookie tidak boleh kosong!"
                continue
            fi

            if validate_cookie_online "$input_cookie"; then
                # Simpan cookie mentah ke antrean
                echo "$input_cookie" >> "$COOKIE_QUEUE"
                i=$((i + 1))
                break 
            else
                echo "   ⚠️  Silakan ambil cookie baru dan paste ulang."
            fi
        done
    done
    
    if [ ! -f "$COOKIE_QUEUE" ]; then
        echo "❌ Tidak ada cookie valid yang diinput. Keluar."
        rm -rf "$TEMP_DB_DIR"
        exit 0
    fi

    total_cookies_input=$(wc -l < "$COOKIE_QUEUE")

    echo "------------------------------------------"
    echo "🚀 TAHAP 2: REFRESH IP & INJECT "
    echo "   (Memproses $total_cookies_input Akun secara berurutan)"
    echo "------------------------------------------"
    
    idx=0
    while read -r valid_cookie; do
        if [ $idx -ge ${#target_pkgs[@]} ]; then break; fi
        
        target_app="${target_pkgs[$idx]}"
        
        echo ""
        echo "⚙️  [$((idx+1))/$total_cookies_input] Sedang memproses: ...${target_app: -15}"
        echo -n "   📡 Refreshing Cookie ke IP Perangkat... "
        
        new_cookie=$(refresh_cookie "$valid_cookie")
        
        # Fallback proteksi jika gagal refresh, tetap pakai cookie asli agar tidak zonk
        if [[ "$new_cookie" == FAIL* ]] || [ -z "$new_cookie" ]; then
            echo "❌ GAGAL ($new_cookie). (Menggunakan cookie awal)"
            new_cookie="$valid_cookie"
        else
            echo "✅ BERHASIL di-refresh!"
        fi
        
        # Generate DB & Inject
        generate_db_file "$((idx+1))" "$new_cookie"
        source_db="$TEMP_DB_DIR/cookie_$((idx+1)).db"
        restore_db "$target_app" "$source_db"
        
        idx=$((idx + 1))
        
        # Berikan delay detik jika bukan cookie terakhir
        if [ $idx -lt $total_cookies_input ]; then
            echo "   ⏳ Menunggu 60 detik (Anti Rate-Limit)..."
            sleep 60
        fi
    done < "$COOKIE_QUEUE"

    rm -rf "$TEMP_DB_DIR"
    rm -f "$COOKIE_QUEUE"
    
    echo "------------------------------------------"
    echo "✨ SELESAI! Semua cookie berhasil di-refresh dan di-inject."
}

check_root
do_main_process
