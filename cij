#!/system/bin/sh

# ==========================================================
# ROBLOX INJECTOR v11.2 (ANTI RATE-LIMIT + FIX SYNTAX)
# ==========================================================

TERMUX_SQLITE="/data/data/com.termux/files/usr/bin/sqlite3"
TMP_SQLITE="/data/local/tmp/sqlite3_exec"
TEMP_DB_DIR="/data/local/tmp/rbx_temp_cookies"
COOKIE_QUEUE="/data/local/tmp/rbx_queue.txt"

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "❌ Script ini MEMBUTUHKAN akses Root!"
        exit 1
    fi
}

prepare_env() {
    if ! command -v curl >/dev/null 2>&1; then
        echo "❌ Curl tidak ditemukan. Install dulu: pkg install curl"
        exit 1
    fi

    rm -f "$TMP_SQLITE"
    if [ -f "$TERMUX_SQLITE" ]; then
        cp "$TERMUX_SQLITE" "$TMP_SQLITE"
        chmod 755 "$TMP_SQLITE"
        SQLITE_BIN="$TMP_SQLITE"
    else
        SQLITE_BIN=$(which sqlite3)
    fi

    if [ -z "$SQLITE_BIN" ] || [ ! -x "$SQLITE_BIN" ]; then
        echo "❌ sqlite3 tidak ditemukan. Wajib install: pkg install sqlite"
        exit 1
    fi

    rm -rf "$TEMP_DB_DIR"
    mkdir -p "$TEMP_DB_DIR"
    chmod 777 "$TEMP_DB_DIR"
}

check_existing_cookie() {
    local pkg="$1"
    local db_path="/data/data/$pkg/app_webview/Default/Cookies"
    
    if [ ! -f "$db_path" ]; then return 1; fi

    local cookie_value=$("$SQLITE_BIN" "$db_path" "SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;" 2>/dev/null)
    
    if [ -n "$cookie_value" ]; then
        return 0 
    else
        return 1 
    fi
}

# --- FUNGSI BARU: RANDOM USER AGENT (SH COMPATIBLE) ---
get_random_ua() {
    # Generate random OS (10 to 14)
    local os_rand=$((RANDOM % 5))
    local os="13"
    case $os_rand in
        0) os="10" ;; 1) os="11" ;; 2) os="12" ;; 3) os="13" ;; 4) os="14" ;;
    esac

    # Generate random Device Model
    local model_rand=$((RANDOM % 7))
    local model="SM-S908B"
    case $model_rand in
        0) model="SM-G991B" ;; 1) model="SM-S901B" ;; 2) model="SM-A536B" ;; 
        3) model="Pixel 6" ;; 4) model="Pixel 7a" ;; 5) model="CPH2023" ;; 6) model="M2101K6G" ;;
    esac

    # Generate random Chrome Version
    local chrome_rand=$((RANDOM % 5))
    local chrome="114.0.5735.196"
    case $chrome_rand in
        0) chrome="114.0.5735.196" ;; 1) chrome="115.0.5790.166" ;; 2) chrome="116.0.5845.163" ;; 
        3) chrome="119.0.6045.163" ;; 4) chrome="120.0.6099.144" ;;
    esac

    echo "Mozilla/5.0 (Linux; Android $os; $model) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/$chrome Mobile Safari/537.36"
}

# --- FUNGSI REFRESH COOKIE ---
refresh_cookie_direct() {
    local old_cookie="$1"
    local current_ua=$(get_random_ua)
    
    echo -n "   ⏳ Refreshing cookie via Direct IP... "

    # 1. Dapatkan CSRF Token
    local csrf=$(curl -s -i -X POST "https://auth.roblox.com/v2/logout" \
        -H "Cookie: .ROBLOSECURITY=$old_cookie" \
        -H "User-Agent: $current_ua" \
        -H "Content-Length: 0" \
        | grep -i "x-csrf-token:" | awk '{print $2}' | tr -d '\r')

    if [ -z "$csrf" ]; then
        echo "❌ Gagal (Token CSRF tidak didapat. Cookie mungkin sudah mati)."
        return 1
    fi

    # 2. Dapatkan Auth Ticket
    local ticket=$(curl -s -i -X POST "https://auth.roblox.com/v1/authentication-ticket" \
        -H "Cookie: .ROBLOSECURITY=$old_cookie" \
        -H "x-csrf-token: $csrf" \
        -H "Referer: https://www.roblox.com/" \
        -H "Origin: https://www.roblox.com" \
        -H "Content-Type: application/json" \
        -H "User-Agent: $current_ua" \
        -d "{}" \
        | grep -i "rbx-authentication-ticket:" | awk '{print $2}' | tr -d '\r')

    if [ -z "$ticket" ]; then
        echo "❌ Gagal (Auth Ticket ditolak API)."
        return 1
    fi

    # 3. Redeem Ticket untuk New Cookie
    local raw_headers=$(curl -s -i -X POST "https://auth.roblox.com/v1/authentication-ticket/redeem" \
        -H "rbxauthenticationnegotiation: 1" \
        -H "Content-Type: application/json" \
        -H "User-Agent: $current_ua" \
        -d "{\"authenticationTicket\": \"$ticket\"}")
    
    local new_cookie=$(echo "$raw_headers" | grep -i "^set-cookie:" | grep -i ".ROBLOSECURITY=" | sed -n 's/.*.ROBLOSECURITY=\([^;]*\).*/\1/p' | head -n 1 | tr -d '\r')

    if [ -n "$new_cookie" ]; then
        # Cek validitas cookie baru & ambil username
        local user_data=$(curl -s -w "\n%{http_code}" -X GET "https://users.roblox.com/v1/users/authenticated" \
            -H "Cookie: .ROBLOSECURITY=$new_cookie" \
            -H "User-Agent: $current_ua")
            
        local http_code=$(echo "$user_data" | tail -n1)
        
        if [ "$http_code" -eq 200 ]; then
            local username=$(echo "$user_data" | grep -o '"name":"[^"]*' | cut -d'"' -f4)
            echo "✅ SUCCESS! (User: $username)"
            FRESH_COOKIE="$new_cookie"
            return 0
        fi
    fi

    echo "❌ Gagal (Redeem berhasil tapi cookie tidak valid/diblokir oleh Rate Limit)."
    return 1
}

generate_db_file() {
    local index="$1"
    local raw_cookie="$2"
    local db_path="$TEMP_DB_DIR/cookie_$index.db"

    rm -f "$db_path"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE cookies(creation_utc INTEGER NOT NULL, top_frame_site_key TEXT NOT NULL, host_key TEXT NOT NULL, name TEXT NOT NULL, value TEXT NOT NULL, encrypted_value BLOB DEFAULT '', path TEXT NOT NULL, expires_utc INTEGER NOT NULL, is_secure INTEGER NOT NULL, is_httponly INTEGER NOT NULL, last_access_utc INTEGER NOT NULL, has_expires INTEGER NOT NULL DEFAULT 1, is_persistent INTEGER NOT NULL DEFAULT 1, priority INTEGER NOT NULL DEFAULT 1, samesite INTEGER NOT NULL DEFAULT -1, source_scheme INTEGER NOT NULL DEFAULT 0, source_port INTEGER NOT NULL DEFAULT -1, is_same_party INTEGER NOT NULL DEFAULT 0, UNIQUE (top_frame_site_key, host_key, name, path));"
    "$SQLITE_BIN" "$db_path" "CREATE TABLE meta(key LONGVARCHAR NOT NULL UNIQUE PRIMARY KEY, value LONGVARCHAR);"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO meta(key, value) VALUES('last_compatible_version','15');"
    "$SQLITE_BIN" "$db_path" "INSERT INTO cookies (creation_utc, top_frame_site_key, host_key, name, value, encrypted_value, path, expires_utc, is_secure, is_httponly, last_access_utc, has_expires, is_persistent, priority, samesite, source_scheme, source_port, is_same_party) VALUES ((strftime('%s','now')*1000000), '', '.roblox.com', '.ROBLOSECURITY', '$raw_cookie', '', '/', 253402300799000000, 1, 1, (strftime('%s','now')*1000000), 1, 1, 1, -1, 1, -1, 0);"
}

restore_db() {
    local pkg_name="$1"
    local source_db="$2"
    local target_root="/data/data/$pkg_name"
    local target_folder="$target_root/app_webview/Default"
    local target_file="$target_folder/Cookies"

    echo "   🔄 Injecting Fresh Cookie to: $pkg_name"
    am force-stop "$pkg_name" > /dev/null 2>&1

    if [ -e "$target_file" ]; then rm -f "$target_file"; fi
    if [ -d "$target_file" ]; then rm -rf "$target_file"; fi

    if [ ! -d "$target_folder" ]; then
        mkdir -p "$target_folder"
        local uid_awal=$(stat -c "%u:%g" "$target_root")
        chown -R "$uid_awal" "$target_root/app_webview"
    fi

    cp "$source_db" "$target_file"
    local app_uid=$(stat -c "%u:%g" "$target_root")
    chown -R "$app_uid" "$target_root/app_webview"
    chmod 660 "$target_file"
}

do_main_process() {
    echo "=========================================="
    echo " ROBLOX INJECTOR v11.2 (ANTI RATE-LIMIT)"
    echo "=========================================="
    prepare_env
    
    raw_pkgs=($(pm list packages | grep "com.roblox.clien" | cut -f 2 -d ":"))
    
    if [ ${#raw_pkgs[@]} -eq 0 ]; then
        echo "❌ Tidak ada aplikasi Roblox Clone."
        return
    fi

    echo "🔍 Memeriksa status login & menyiapkan target..."
    target_pkgs=()

    for pkg in "${raw_pkgs[@]}"; do
        if check_existing_cookie "$pkg"; then
            echo "   ⚠️ TARGET: $pkg (Sudah Login -> AKAN DITIMPA)"
        else
            echo "   🎯 TARGET: $pkg (Kosong -> Perlu Injeksi)"
        fi
        target_pkgs+=("$pkg")
    done

    total_targets=${#target_pkgs[@]}

    if [ $total_targets -eq 0 ]; then
        echo "✅ Tidak ada target yang bisa diproses. Keluar."
        rm -rf "$TEMP_DB_DIR"
        exit 0
    fi

    echo "------------------------------------------"
    echo "📝 Mengisi $total_targets slot aplikasi."
    echo "   Ketik 'done' untuk batal/keluar."
    echo "------------------------------------------"
    
    rm -f "$COOKIE_QUEUE"
    
    i=0
    while [ $i -lt $total_targets ]; do
        display_num=$((i + 1))
        current_target_pkg="${target_pkgs[$i]}"
        
        while true; do
            echo ""
            echo "👉 [$display_num/$total_targets] Target: ...${current_target_pkg: -15}"
            echo -n "   Paste Old Cookie: "
            read -r input_cookie

            if [ "$input_cookie" = "done" ]; then 
                echo "⚠️  Proses dihentikan user."
                break 2 
            fi

            if [ -z "$input_cookie" ]; then
                echo "   ❌ Cookie tidak boleh kosong!"
                continue
            fi

            FRESH_COOKIE=""
            if refresh_cookie_direct "$input_cookie"; then
                echo "$FRESH_COOKIE" >> "$COOKIE_QUEUE"
                
                # Tambahkan Delay Jika Bukan Target Terakhir
                if [ $((i + 1)) -lt $total_targets ]; then
                    echo "   ⏳ Jeda 7 detik menghindari API Rate Limit..."
                    sleep 7
                fi
                
                i=$((i + 1))
                break 
            else
                echo "   ⚠️  Cookie lama mati atau gagal direfresh. Coba cookie lain."
            fi
        done
    done
    
    total_cookies_input=$i

    if [ $total_cookies_input -eq 0 ]; then
        echo "❌ Tidak ada cookie valid yang diinput."
        rm -rf "$TEMP_DB_DIR"
        exit 0
    fi

    echo "------------------------------------------"
    echo "🚀 Memproses & Mengirim ke Aplikasi..."
    
    idx=0
    while read -r fresh_cookie; do
        if [ $idx -ge ${#target_pkgs[@]} ]; then break; fi
        
        generate_db_file "$((idx+1))" "$fresh_cookie"
        
        target_app="${target_pkgs[$idx]}"
        source_db="$TEMP_DB_DIR/cookie_$((idx+1)).db"
        
        restore_db "$target_app" "$source_db"
        
        idx=$((idx + 1))
    done < "$COOKIE_QUEUE"

    rm -rf "$TEMP_DB_DIR"
    rm -f "$COOKIE_QUEUE"
    
    echo "------------------------------------------"
    echo "✨ SELESAI! Cookie baru dengan IP Local berhasil di-inject."
}

check_root
do_main_process
