local UnsoldFishCount = 0

local function StartBackgroundTasks()
    task.spawn(function()
        while true do
            if PlayerData and RE_FavoriteItem then
                pcall(function()
                    local inv = PlayerData:Get("Inventory")
                    for _, items in pairs(inv) do
                        for _, item in ipairs(items) do
                            if item.UUID then
                                local itemName = GetFishNameAndRarity(item)
