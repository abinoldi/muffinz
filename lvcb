local function GetRuinDoorStatus()
    local ruinInteractions = workspace:FindFirstChild("RUIN INTERACTIONS")
    if not ruinInteractions then return "NO_FOLDER" end
    
    local ruinDoor = ruinInteractions:FindFirstChild("Door")
    if not ruinDoor then return "NO_DOOR" end
    
    if ruinDoor:FindFirstChild("RuinDoor") then
        local LDoor = ruinDoor.RuinDoor:FindFirstChild("LDoor")
        if LDoor then
            local currentX = nil
            if LDoor:IsA("BasePart") then 
                currentX = LDoor.Position.X
                print("[DEBUG] LDoor X (BasePart):", currentX)
            elseif LDoor:IsA("Model") then 
                local s, p = pcall(function() return LDoor:GetPivot() end) 
                if s and p then 
                    currentX = p.Position.X
                    print("[DEBUG] LDoor X (Model):", currentX)
                end
            end
            if currentX ~= nil and currentX > 6075 then 
                return "UNLOCKED" 
            elseif currentX ~= nil then
                return "LOCKED (X=" .. math.floor(currentX) .. ")"
            end
        end
    end
    return "UNKNOWN"
end

