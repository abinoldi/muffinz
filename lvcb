-- FUNGSI HasArtifactItem (TETAP SAMA)
local function HasArtifactItem(artifactName)
    -- Cek langsung ke tas fisik untuk kecepatan
    if lp.Character then
        for _, v in ipairs(lp.Character:GetChildren()) do
            if v:IsA("Tool") and string.find(v.Name, artifactName) then return true end
        end
    end
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, v in ipairs(backpack:GetChildren()) do
            if v:IsA("Tool") and string.find(v.Name, artifactName) then return true end
        end
    end

    if not PlayerData then return false end
    local hasItem = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        local targetId = ARTIFACT_IDS[artifactName]
        for _, items in pairs(inv) do
            for _, item in ipairs(items) do
                if tonumber(item.Id) == targetId then hasItem = true return end
            end
        end
    end)
    return hasItem
end

-- FUNGSI DoAutoLever YANG DIPERBAIKI (MENGGUNAKAN FUNGSI BARU)
local function DoAutoLever()
    print("⏳ [FASE 1] Memulai Auto Lever Temple...")
    
    -- Tampilkan status awal
    DebugLeverStatus()
    
    while true do
        local unlockedArtifacts = GetUnlockedArtifacts()
        local allUnlocked = true
        local artifactToProcess = nil
        
        for _, artifactName in ipairs(ArtifactOrder) do
            local isUnlocked = unlockedArtifacts[artifactName] == true
            if not isUnlocked and not artifactToProcess then
                artifactToProcess = artifactName
            end
            if not isUnlocked then allUnlocked = false end
        end

        if allUnlocked then
            print("✅ [Auto Lever] SEMUA LEVER SUDAH UNLOCKED!")
            print("📊 Detail status lever (berdasarkan cyclic shift):")
            for _, artifactName in ipairs(ArtifactOrder) do
                print("   ✅ " .. artifactName .. " : TERBUKA")
            end
            break
        elseif artifactToProcess then
            local artData = ArtifactData[artifactToProcess]
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")

            if HasArtifactItem(artifactToProcess) then
                print("🔧 [Auto Lever] Memproses: " .. artifactToProcess .. " (Item tersedia)")
                _G.PauseFishing = true 
                task.wait(0.5)
                
                if hrp and (hrp.Position - artData.TargetPos.Pos).Magnitude > 5 then
                    print("🏃 [Teleport] Menuju ke lokasi pemasangan: " .. artifactToProcess)
                    TeleportToLookAt(artData.TargetPos.Pos, artData.TargetPos.Look)
                    task.wait(1.5) 
                end

                if hrp then hrp.Anchored = true end
                
                -- AUTO EQUIP ARTIFACT
                local backpack = lp:FindFirstChild("Backpack")
                if hum and backpack then
                    for _, tool in ipairs(backpack:GetChildren()) do
                        if tool:IsA("Tool") and string.find(tool.Name, artifactToProcess) then
                            hum:EquipTool(tool)
                            print("🎒 [Equip] Memegang " .. tool.Name)
                            break
                        end
                    end
                end
                
                task.wait(1.5)
                
                print("🔧 [Auto Lever] Memasang Artifact: " .. artifactToProcess)
                if RE_PlaceLeverItem then FireRemote(RE_PlaceLeverItem, artifactToProcess) end
                task.wait(2.5) 
                
                if hrp then hrp.Anchored = false end
                
                -- Update status setelah pemasangan
                task.wait(1)
                print("🔄 Mengecek ulang status lever...")
            else
                print("🎣 [Auto Lever] Farming untuk: " .. artifactToProcess .. " (Item belum tersedia)")
                _G.PauseFishing = false 
                if hrp and (hrp.Position - artData.FishingPos.Pos).Magnitude > 5 then
                    print("🎣 [Teleport] Menuju lokasi memancing Artifact: " .. artifactToProcess)
                    TeleportToLookAt(artData.FishingPos.Pos, artData.FishingPos.Look)
                    task.wait(1.5)
                end
                task.wait(1) 
            end
        end
        task.wait(0.1)
    end
end

