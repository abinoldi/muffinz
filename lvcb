    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, v in ipairs(backpack:GetChildren()) do
            if v:IsA("Tool") and v.Name == itemName then return true end
        end
    end

    -- Cek di PlayerData
    if not PlayerData then return false end
    local hasItem = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        for _, items in pairs(inv) do
            for _, item in ipairs(items) do
                if GetFishNameAndRarity(item) == itemName then 
                    hasItem = true 
                    return 
                end
            end
        end
    end)
    return hasItem
end

local function GetMissingItems()
    local missing = {}
    for _, name in ipairs(ITEM_FISH_NAMES) do
        if not IsItemAvailable(name) then
            table.insert(missing, name)
        end
    end
    return missing
end

local function GetAllItemsStatus()
    local status = {}
    for _, name in ipairs(ITEM_FISH_NAMES) do
        status[name] = IsItemAvailable(name)
    end
    return status
end

local function DoAutoRuin()
    print("⏳ [FASE 2] Memulai Auto Ruin Door...")
    print("📍 Target: Membuka Ruin Door di Ancient Ruin")
    print("🎯 Butuh 4 item: Freshwater Piranha, Goliath Tiger, Sacred Guardian Squid, Crocodile")
    
    local runningRuin = true
    local lastStatus = ""
    local lastMissingCount = 4
    local attemptCount = 0
    local maxAttempts = 50 -- Maksimal 50 iterasi sebelum reset posisi
    
    -- THREAD 1: Background spammer untuk unlock door (tetap jalan)
    local spammerThread = task.spawn(function()
        local spamCounter = 0
        while runningRuin do
            local doorStatus = GetRuinDoorStatus()
            if doorStatus == "UNLOCKED" then
                print("✅ [Spammer] Door sudah UNLOCKED, menghentikan spam...")
                break
            end
            
            if RE_PlacePressureItem then
                spamCounter = spamCounter + 1
                print("🔄 [Spammer #" .. spamCounter .. "] Mencoba unlock dengan semua item...")
                for _, name in ipairs(ITEM_FISH_NAMES) do
                    if runningRuin then
                        FireRemote(RE_PlacePressureItem, name)
                        task.wait(0.5)
                    end
                end
            end
            task.wait(3)
        end
    end)

    -- THREAD 2: Main logic untuk farming dan teleport
    while runningRuin do
        attemptCount = attemptCount + 1
        local doorStatus = GetRuinDoorStatus()
        local missingItems = GetMissingItems()
        local missingCount = #missingItems
        local allItemsStatus = GetAllItemsStatus()
        
        -- Status update setiap 5 iterasi
        if attemptCount % 5 == 1 or missingCount ~= lastMissingCount or doorStatus ~= lastStatus then
            print("\n📊 [Status Ruin Door] " .. doorStatus)
            print("📦 [Inventory] Item yang dimiliki:")
            for name, available in pairs(allItemsStatus) do
                local icon = available and "✅" or "❌"
                print("   " .. icon .. " " .. name)
            end
            
            if missingCount > 0 then
                print("🎣 [Farming] Butuh " .. missingCount .. " item: " .. table.concat(missingItems, ", "))
            else
                print("🎉 [Inventory] SEMUA ITEM LENGKAP! Siap unlock door.")
            end
            
            lastStatus = doorStatus
            lastMissingCount = missingCount
        end

        -- CEK KONDISI SELESAI
        if doorStatus == "UNLOCKED" then
            print("\n✅ [Auto Ruin] RUIN DOOR SUDAH UNLOCKED! Misi selesai.")
            runningRuin = false
            break
        end

        -- CEK JIKA ADA ITEM YANG KURANG
        if missingCount > 0 then
            -- Butuh item, aktifkan fishing
            _G.PauseFishing = false 
            
            -- Cek posisi, kalau tidak di Sacred Temple, teleport
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local distToFarm = (hrp.Position - FARM_POS).Magnitude
                if distToFarm > 20 then
                    print("🏃 [Teleport] Menuju Sacred Temple untuk farming (jarak: " .. math.floor(distToFarm) .. ")")
                    TeleportToLookAt(FARM_POS, FARM_LOOK)
                    task.wait(2)
                else
                    -- Sudah di lokasi, reset attempt counter biar ga ke-reset posisi
                    attemptCount = 0
                end
            end
            task.wait(1)
            
        else
            -- Semua item lengkap, fokus ke unlock door
            _G.PauseFishing = true 
            
            -- Cek posisi, kalau tidak di Ancient Ruin, teleport
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local distToRuin = (hrp.Position - RUIN_DOOR_POS).Magnitude
                if distToRuin > 20 then
                    print("🏃 [Teleport] Menuju Ancient Ruin untuk unlock door (jarak: " .. math.floor(distToRuin) .. ")")
                    TeleportToLookAt(RUIN_DOOR_POS, RUIN_DOOR_LOOK)
                    task.wait(2)
                end
            end
            
            -- Reset posisi jika terlalu lama stuck (50 iterasi di tempat yang sama)
            if attemptCount > maxAttempts then
                print("⚠️ [Warning] Terlalu lama di posisi yang sama, mereset posisi...")
                if hrp then
                    TeleportToLookAt(RUIN_DOOR_POS, RUIN_DOOR_LOOK)
                    task.wait(1)
                end
                attemptCount = 0
            end
            
            task.wait(1)
        end
    end
    
    -- Bersihkan thread spammer
    if spammerThread then
        task.cancel(spammerThread)
    end
    
    _G.IsAutoFishing = false
    print("✅ [Auto Ruin] Selesai!")
end

