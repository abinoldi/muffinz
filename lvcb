local ITEM_FISH_NAMES = {"Freshwater Piranha", "Goliath Tiger", "Sacred Guardian Squid", "Crocodile"}
local FishToRarity = {
    ["Freshwater Piranha"] = "Rare",
    ["Goliath Tiger"] = "Epic",
    ["Sacred Guardian Squid"] = "Legendary",
    ["Crocodile"] = "Mythic"
}

local function GetRuinDoorStatus()
    local ruinDoor = workspace:FindFirstChild("RUIN INTERACTIONS") and workspace["RUIN INTERACTIONS"]:FindFirstChild("Door")
    local status = "LOCKED"
    if ruinDoor and ruinDoor:FindFirstChild("RuinDoor") then
        local LDoor = ruinDoor.RuinDoor:FindFirstChild("LDoor")
        if LDoor then
            local currentX = nil
            if LDoor:IsA("BasePart") then currentX = LDoor.Position.X
            elseif LDoor:IsA("Model") then local s, p = pcall(function() return LDoor:GetPivot() end) if s and p then currentX = p.Position.X end end
            if currentX ~= nil and currentX > 6075 then status = "UNLOCKED" end
        end
    end
    _G.RuinStatusStr = status
    return status
end

local function IsItemAvailable(itemName)
    if not PlayerData then return false end
    local hasItem = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        for _, items in pairs(inv) do
            for _, item in ipairs(items) do
                if GetFishNameAndRarity(item) == itemName then hasItem = true return end
            end
        end
    end)
    return hasItem
end

local function IsFishPlaced(itemName)
    local ruinFolder = workspace:FindFirstChild("RUIN INTERACTIONS")
    local platesFolder = ruinFolder and ruinFolder:FindFirstChild("PressurePlates")
    if not platesFolder then return false end

    local rarity = FishToRarity[itemName]
    if not rarity then return false end

    local plateModel = platesFolder:FindFirstChild(rarity)
    if plateModel then
        local movePart = plateModel:FindFirstChild("MOVE_PART")
        local stepPlate = movePart and movePart:FindFirstChild("StepPlate")
        
        if stepPlate and stepPlate.Position.Y < -541.1 then
            return true
        end
    end
    return false
end

local function GetMissingItem()
    for _, name in ipairs(ITEM_FISH_NAMES) do
        if not IsFishPlaced(name) and not IsItemAvailable(name) then 
            return name 
        end
    end
    return nil
end

local function DoAutoRuin()
    _G.CurrentPhase = "Auto Ruin Door (2/2)"
    
    local runningRuin = true
    task.spawn(function()
        while runningRuin do
            if GetRuinDoorStatus() == "LOCKED" and RE_PlacePressureItem then
                for _, name in ipairs(ITEM_FISH_NAMES) do
                    if IsItemAvailable(name) and not IsFishPlaced(name) then
                        _G.CurrentAction = "Memasang: " .. name
                        FireRemote(RE_PlacePressureItem, name)
                        task.wait(2.1)
                    end
                end
            end
            task.wait(3)
        end
    end)

    while true do
        local doorStatus = GetRuinDoorStatus()
        if doorStatus == "UNLOCKED" then
            _G.CurrentAction = "Ruin Door Terbuka!"
            runningRuin = false
            break -- Selesai fase Ruin, meluncur ke fase abadi
        end

        local missingItem = GetMissingItem()
        _G.CurrentTargetFish = missingItem -- Sinkronisasi ke sistem Smart Favorite

        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if missingItem then
            _G.CurrentAction = "Farming: " .. missingItem
            _G.PauseFishing = false 
            if hrp and (hrp.Position - FishingAreas["Sacred Temple"].Pos).Magnitude > 5 then
                TeleportToLookAt(FishingAreas["Sacred Temple"].Pos, FishingAreas["Sacred Temple"].Look)
                task.wait(1.5)
            end
            task.wait(1) 
        else
            _G.CurrentAction = "Menunggu Pintu Ruin..."
            _G.PauseFishing = true 
            task.wait(0.5)
            if hrp and (hrp.Position - FishingAreas["Ancient Ruin"].Pos).Magnitude > 50 then
                 TeleportToLookAt(FishingAreas["Ancient Ruin"].Pos, FishingAreas["Ancient Ruin"].Look)
                 task.wait(1.5)
            end
            task.wait(1)
        end
    end
end

