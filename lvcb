        TargetPos = FishingAreas["Arrow Lever"],
        ChildId = 5
    },
    ["Crescent Artifact"] = { 
        FishingPos = {Pos = Vector3.new(1401.070, 6.489, 116.738), Look = Vector3.new(-0.500, -0.000, 0.866)},
        TargetPos = FishingAreas["Cresent Lever"],
        ChildId = 4
    },
}
local ArtifactOrder = {"Hourglass Diamond Artifact", "Diamond Artifact", "Arrow Artifact", "Crescent Artifact"}
local ARTIFACT_IDS = { ["Arrow Artifact"] = 265, ["Crescent Artifact"] = 266, ["Diamond Artifact"] = 267, ["Hourglass Diamond Artifact"] = 271 }

local function IsLeverUnlocked(artifactName)
    local JUNGLE = workspace:FindFirstChild("JUNGLE INTERACTIONS")
    if not JUNGLE then return false end
    local data = ArtifactData[artifactName]
    local folder = (type(data.ChildId) == "string") and JUNGLE:FindFirstChild(data.ChildId) or JUNGLE:GetChildren()[data.ChildId]
    if not folder then return false end
    local crystal = folder:FindFirstChild("Crystal")
    if not crystal then return false end
    
    local color = crystal.Color
    local isBright = (color.r + color.g + color.b) > 0.5
    
    if artifactName == "Hourglass Diamond Artifact" and color.r > 0.5 and color.g > 0.5 then return true end
    if artifactName == "Diamond Artifact" and color.r > 0.4 and color.b > 0.4 then return true end
    if artifactName == "Arrow Artifact" and color.r > 0.6 and color.g < 0.3 then return true end
    if artifactName == "Crescent Artifact" and color.g > 0.6 and color.r < 0.4 then return true end
    return false
end

local function HasArtifactInInventory(artifactName)
    if lp.Character and lp.Character:FindFirstChild(artifactName) then return true end
    if lp:FindFirstChild("Backpack") and lp.Backpack:FindFirstChild(artifactName) then return true end
    local has = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        local id = ARTIFACT_IDS[artifactName]
        for _, group in pairs(inv) do
            for _, item in ipairs(group) do if tonumber(item.Id) == id then has = true break end end
        end
    end)
    return has
end

local function DoAutoLever()
    for _, name in ipairs(ArtifactOrder) do
        while true do
            if IsLeverUnlocked(name) then break end
            if HasArtifactInInventory(name) then
                _G.PauseFishing = true
                task.wait(0.5)
                TeleportToLookAt(ArtifactData[name].TargetPos.Pos, ArtifactData[name].TargetPos.Look)
                task.wait(1)
                
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                local hum = lp.Character and lp.Character:FindFirstChild("Humanoid")
                local tool = lp.Backpack:FindFirstChild(name) or lp.Character:FindFirstChild(name)
                
                if hrp then hrp.Anchored = true end
                if hum and tool then hum:EquipTool(tool) end
                task.wait(1)
                
                FireRemote(RE_PlaceLeverItem, name)
                task.wait(3)
                if hrp then hrp.Anchored = false end
                if not HasArtifactInInventory(name) or IsLeverUnlocked(name) then break end
            else
                _G.PauseFishing = false
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp and (hrp.Position - ArtifactData[name].FishingPos.Pos).Magnitude > 10 then
                    TeleportToLookAt(ArtifactData[name].FishingPos.Pos, ArtifactData[name].FishingPos.Look)
                    task.wait(1)
                end
                task.wait(1)
            end
            task.wait(0.5)
        end
    end
end

