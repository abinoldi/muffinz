                            if item.UUID then
                                local itemName = GetFishNameAndRarity(item)
                                -- Hanya favorite ikan yang SEKARANG jadi target
                                if itemName == _G.CurrentTargetFish and not (item.IsFavorite or item.Favorited or item.Locked) then
                                    RE_FavoriteItem:FireServer(item.UUID)
                                    print("⭐ [Smart Favorite] Mengamankan target: " .. itemName)
                                end
                            end
                        end
                    end
                end)
            end
            task.wait(2.5)
        end
    end)

    if RE_ObtainedNewFishNotification then
        RE_ObtainedNewFishNotification.OnClientEvent:Connect(function() 
            _G.UnsoldFishCount = _G.UnsoldFishCount + 1 
            _G.TotalFishCaught = _G.TotalFishCaught + 1
        end)
