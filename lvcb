local ArtifactOrder = {"Hourglass Diamond Artifact", "Diamond Artifact", "Arrow Artifact", "Crescent Artifact"}
local ARTIFACT_IDS = { ["Arrow Artifact"] = 265, ["Crescent Artifact"] = 266, ["Diamond Artifact"] = 267, ["Hourglass Diamond Artifact"] = 271 }

local function IsLeverUnlocked(artifactName)
    local JUNGLE = workspace:FindFirstChild("JUNGLE INTERACTIONS")
    if not JUNGLE then return false end
    local data = ArtifactData[artifactName]
    local folder = (type(data.ChildReference) == "string") and JUNGLE:FindFirstChild(data.ChildReference) or JUNGLE:GetChildren()[data.ChildReference]
    if not folder then return false end
    local crystal = folder:FindFirstChild(data.CrystalPathSuffix)
    if not crystal or not crystal:IsA("BasePart") then return false end
    local cC, tC = crystal.Color, data.UnlockColor
    return (math.abs(cC.R*255 - tC.R*255) < 1.1 and math.abs(cC.G*255 - tC.G*255) < 1.1 and math.abs(cC.B*255 - tC.B*255) < 1.1)
end

local function HasArtifactItem(artifactName)
    if not PlayerData then return false end
    local hasItem = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        local targetId = ARTIFACT_IDS[artifactName]
        for _, items in pairs(inv) do
            for _, item in ipairs(items) do
                if tonumber(item.Id) == targetId then hasItem = true return end
            end
        end
    end)
    return hasItem
end

local function DoAutoLever()
    print("⏳ [FASE 1] Memulai Auto Lever Temple...")
    while true do
        local allUnlocked = true
        local artifactToProcess = nil
        
        for _, artifactName in ipairs(ArtifactOrder) do
            local isUnlocked = IsLeverUnlocked(artifactName)
            if not isUnlocked and not artifactToProcess then artifactToProcess = artifactName end
            if not isUnlocked then allUnlocked = false end
        end

        if allUnlocked then
            print("✅ [Auto Lever] SEMUA LEVER SUDAH UNLOCKED!")
            break
        elseif artifactToProcess then
            local artData = ArtifactData[artifactToProcess]
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if HasArtifactItem(artifactToProcess) then
                -- [ HARD PAUSE FISHING AGAR TIDAK BENTROK ] --
                _G.PauseFishing = true 
                FishingConfig.AutoEquip = false 
                task.wait(1) -- Beri waktu pancingan agar benar-benar berhenti beroperasi
                
                if hrp and (hrp.Position - artData.TargetPos.Pos).Magnitude > 5 then
                    print("🏃 [Teleport] Menuju ke lokasi pemasangan: " .. artifactToProcess)
                    TeleportToLookAt(artData.TargetPos.Pos, artData.TargetPos.Look)
                    task.wait(1.5) 
                end

                print("🔧 [Auto Lever] Memasang Artifact: " .. artifactToProcess)
                if hrp then hrp.Anchored = true end
                
                -- Lepas pancingan (Aman karena AutoEquip sudah kita tembak mati sementara)
                if Remote_EquipTool then pcall(function() if Remote_EquipTool:IsA("RemoteFunction") then Remote_EquipTool:InvokeServer(0) else Remote_EquipTool:FireServer(0) end end) end
                task.wait(0.5)
                
                -- Pasang Lever
                if RE_PlaceLeverItem then FireRemote(RE_PlaceLeverItem, artifactToProcess) end
                task.wait(2.5) 
                
                if hrp then hrp.Anchored = false end
            else
                -- [ LANJUTKAN MEMANCING ] --
                _G.PauseFishing = false 
                FishingConfig.AutoEquip = true 
                
                if hrp and (hrp.Position - artData.FishingPos.Pos).Magnitude > 5 then
                    print("🎣 [Teleport] Menuju lokasi memancing Artifact: " .. artifactToProcess)
                    TeleportToLookAt(artData.FishingPos.Pos, artData.FishingPos.Look)
                    task.wait(1.5)
                end
            end
        end
        task.wait(0.1)
    end
end

