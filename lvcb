-- ======================================================
-- 7. WORKFLOW EXECUTION
-- ======================================================
local ArtifactOrder = {"Hourglass Diamond Artifact", "Diamond Artifact", "Arrow Artifact", "Crescent Artifact"}
local ARTIFACT_IDS = { ["Arrow Artifact"] = 265, ["Crescent Artifact"] = 266, ["Diamond Artifact"] = 267, ["Hourglass Diamond Artifact"] = 271 }

local function HasArtifact(name)
    if lp.Character:FindFirstChild(name) or lp.Backpack:FindFirstChild(name) then return true end
    local h = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        local id = ARTIFACT_IDS[name]
        for _, g in pairs(inv) do for _, i in ipairs(g) do if tonumber(i.Id) == id then h = true break end end end
    end)
    return h
end

task.spawn(function()
    pcall(function() require(Services.ReplicatedStorage.Controllers.AutoFishingController):Stop() end)

    -- FASE 1: LEVERS
    for _, name in ipairs(ArtifactOrder) do
        while not IsLeverUnlocked(name) do
            if HasArtifact(name) then
                _G.PauseFishing = true
                TeleportToLookAt(ArtifactData[name].TargetPos.Pos, ArtifactData[name].TargetPos.Look)
                task.wait(1)
                local tool = lp.Backpack:FindFirstChild(name) or lp.Character:FindFirstChild(name)
                if lp.Character.Humanoid and tool then lp.Character.Humanoid:EquipTool(tool) end
                task.wait(1)
                FireRemote(RE_PlaceLeverItem, name)
                task.wait(3)
            else
                _G.PauseFishing = false
                TeleportToLookAt(ArtifactData[name].FishingPos.Pos, ArtifactData[name].FishingPos.Look)
            end
            task.wait(1)
        end
    end

    -- FASE 2: RUIN
    while not GetRuinDoorStatus() do
        local hasAll = true
        pcall(function()
            local inv = PlayerData:Get("Inventory")
            for _, f in ipairs({"Freshwater Piranha", "Goliath Tiger", "Sacred Guardian Squid", "Crocodile"}) do
                local found = false
                for _, g in pairs(inv) do for _, i in ipairs(g) do if GetFishNameAndRarity(i) == f then found = true break end end end
                if not found then hasAll = false break end
            end
        end)
        if hasAll then
            _G.PauseFishing = true
            TeleportToLookAt(FishingAreas["Ancient Ruin"].Pos, FishingAreas["Ancient Ruin"].Look)
            for _, n in ipairs({"Freshwater Piranha", "Goliath Tiger", "Sacred Guardian Squid", "Crocodile"}) do
                FireRemote(RE_PlacePressureItem, n)
                task.wait(2.1)
            end
        else
            _G.PauseFishing = false
            TeleportToLookAt(FishingAreas["Sacred Temple"].Pos, FishingAreas["Sacred Temple"].Look)
        end
        task.wait(5)
    end

    _G.IsAutoFishing = false
    print("✅ MISSION COMPLETED!")
end)
