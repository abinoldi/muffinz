-- ======================================================
local ITEM_FISH_NAMES = {"Freshwater Piranha", "Goliath Tiger", "Sacred Guardian Squid", "Crocodile"}

local function GetRuinDoorStatus()
    local ruinDoor = workspace:FindFirstChild("RUIN INTERACTIONS") and workspace["RUIN INTERACTIONS"]:FindFirstChild("Door")
    local status = "LOCKED"
    if ruinDoor and ruinDoor:FindFirstChild("RuinDoor") then
        local LDoor = ruinDoor.RuinDoor:FindFirstChild("LDoor")
        if LDoor then
            local currentX = nil
            if LDoor:IsA("BasePart") then currentX = LDoor.Position.X
            elseif LDoor:IsA("Model") then local s, p = pcall(function() return LDoor:GetPivot() end) if s and p then currentX = p.Position.X end end
            if currentX ~= nil and currentX > 6075 then status = "UNLOCKED" end
        end
    end
    return status
end

local function IsItemAvailable(itemName)
    if not PlayerData then return false end
    local hasItem = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        for _, items in pairs(inv) do
            for _, item in ipairs(items) do
                if GetFishNameAndRarity(item) == itemName then hasItem = true return end
            end
        end
    end)
    return hasItem
end

local function GetMissingItem()
    for _, name in ipairs(ITEM_FISH_NAMES) do
        if not IsItemAvailable(name) then return name end
    end
    return nil
end

local function DoAutoRuin()
    print("⏳ [FASE 2] Memulai Auto Ruin Door...")
    
    local runningRuin = true
    task.spawn(function()
        while runningRuin do
            if GetRuinDoorStatus() == "LOCKED" and RE_PlacePressureItem then
                for _, name in ipairs(ITEM_FISH_NAMES) do
                    task.wait(2.1)
                    FireRemote(RE_PlacePressureItem, name)
                end
            end
            task.wait(5)
        end
    end)

    while true do
        local doorStatus = GetRuinDoorStatus()
        if doorStatus == "UNLOCKED" then
            print("✅ [Auto Ruin] RUIN DOOR SUDAH UNLOCKED!")
            runningRuin = false
            _G.IsAutoFishing = false -- Hentikan sepenuhnya fishing karena game sudah tamat
            break
        end

        local missingItem = GetMissingItem()
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if missingItem then
            _G.PauseFishing = false 
            FishingConfig.AutoEquip = true 
            
            if hrp and (hrp.Position - FishingAreas["Sacred Temple"].Pos).Magnitude > 5 then
                print("🎣 [Auto Ruin] Kurang Bahan! Teleport ke Sacred Temple mencari: " .. missingItem)
                TeleportToLookAt(FishingAreas["Sacred Temple"].Pos, FishingAreas["Sacred Temple"].Look)
                task.wait(1.5)
            end
            task.wait(1) 
        else
            -- MATIKAN PANCINGAN AGAR BISA MASUK RUIN DOOR DENGAN TENANG
            _G.PauseFishing = true 
            FishingConfig.AutoEquip = false 
            task.wait(1)
            
            if hrp and (hrp.Position - FishingAreas["Ancient Ruin"].Pos).Magnitude > 50 then
                 print("🏃 [Auto Ruin] Semua bahan siap, menuju Ruin Door!")
                 TeleportToLookAt(FishingAreas["Ancient Ruin"].Pos, FishingAreas["Ancient Ruin"].Look)
                 task.wait(1.5)
            end
            task.wait(1)
        end
    end
end

