local CachedRemotes = {}
local TargetRemotes = {
    "RF/ChargeFishingRod", "RF/RequestFishingMinigameStarted", "RF/CatchFishCompleted", "RE/FishingCompleted",
    "RF/EquipToolFromHotbar", "RE/EquipToolFromHotbar", "RE/FavoriteItem", "RE/PlaceLeverItem",
    "RE/PlacePressureItem", "RF/CancelFishingInputs", "RF/SellAllItems", "RE/ObtainedNewFishNotification"
}

local function InitializeRemotes()
    local netFolder = Services.ReplicatedStorage:WaitForChild("Packages", 5):WaitForChild("_Index", 5):WaitForChild("sleitnick_net@0.2.0", 5):WaitForChild("net", 5)
    if netFolder then
        local children = netFolder:GetChildren()
        local targetMap = {}
        for _, name in ipairs(TargetRemotes) do targetMap[name] = true end
        for i = 1, #children do
            if targetMap[children[i].Name] and i < #children then
                CachedRemotes[children[i].Name] = children[i + 1]
            end
        end
    end
end
InitializeRemotes()

local RF_ChargeFishingRod = CachedRemotes["RF/ChargeFishingRod"]
