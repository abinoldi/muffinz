-- 7. RUIN DOOR LOGIC (FASE 2)
-- ======================================================
local function GetRuinDoorStatus()
    local ruinDoor = workspace:FindFirstChild("RUIN INTERACTIONS") and workspace["RUIN INTERACTIONS"]:FindFirstChild("Door")
    if ruinDoor and ruinDoor:FindFirstChild("RuinDoor") then
        local LDoor = ruinDoor.RuinDoor:FindFirstChild("LDoor")
        if LDoor and LDoor.Position.X > 6075 then return "UNLOCKED" end
    end
    return "LOCKED"
end

local function GetMissingRuinItem()
    for _, name in ipairs({"Freshwater Piranha", "Goliath Tiger", "Sacred Guardian Squid", "Crocodile"}) do
        local has = false
        pcall(function()
            for _, g in pairs(PlayerData:Get("Inventory")) do
                for _, i in ipairs(g) do if GetFishNameAndRarity(i) == name then has = true break end end
            end
        end)
        if not has then return name end
    end
    return nil
end

local function DoAutoRuin()
    print("⏳ [FASE 2] Memulai Auto Ruin Door...")
    task.spawn(function()
        while GetRuinDoorStatus() == "LOCKED" do
            for _, n in ipairs({"Freshwater Piranha", "Goliath Tiger", "Sacred Guardian Squid", "Crocodile"}) do
                task.wait(2.1)
                FireRemote(RE_PlacePressureItem, n)
            end
            task.wait(5)
        end
    end)
    while GetRuinDoorStatus() == "LOCKED" do
        local missing = GetMissingRuinItem()
        if missing then
            _G.PauseFishing = false
            TeleportToLookAt(FishingAreas["Sacred Temple"].Pos, FishingAreas["Sacred Temple"].Look)
            task.wait(1.5)
        else
            _G.PauseFishing = true
            TeleportToLookAt(FishingAreas["Ancient Ruin"].Pos, FishingAreas["Ancient Ruin"].Look)
            task.wait(2)
        end
        task.wait(1)
    end
end

