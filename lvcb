-- FUNGSI ASLI (JANGAN DIHAPUS/MODIFIKASI)
local function OriginalIsLeverUnlocked(artifactName)
    local JUNGLE = workspace:FindFirstChild("JUNGLE INTERACTIONS")
    if not JUNGLE then return false end
    local data = ArtifactData[artifactName]
    local folder = (type(data.ChildReference) == "string") and JUNGLE:FindFirstChild(data.ChildReference) or JUNGLE:GetChildren()[data.ChildReference]
    if not folder then return false end
    local crystal = folder:FindFirstChild(data.CrystalPathSuffix)
    if not crystal or not crystal:IsA("BasePart") then return false end
    local cC, tC = crystal.Color, data.TargetColor
    return (math.abs(cC.R*255 - tC.R*255) < 1.1 and math.abs(cC.G*255 - tC.G*255) < 1.1 and math.abs(cC.B*255 - tC.B*255) < 1.1)
end

-- FUNGSI BARU UNTUK DETEKSI CYCLIC SHIFT (TAMBAHAN, TIDAK MENGGANTI YANG LAMA)
local ColorMapping = {
    [string.format("%d,%d,%d", 219, 38, 255)] = "Diamond Artifact",           -- Ungu milik Diamond
    [string.format("%d,%d,%d", 255, 47, 47)] = "Arrow Artifact",               -- Merah milik Arrow
    [string.format("%d,%d,%d", 255, 248, 49)] = "Hourglass Diamond Artifact", -- Kuning milik Hourglass
    [string.format("%d,%d,%d", 112, 255, 69)] = "Crescent Artifact",           -- Hijau milik Crescent
}

local CrystalColorCache = {}

local function ScanCrystalColors()
    local JUNGLE = workspace:FindFirstChild("JUNGLE INTERACTIONS")
    if not JUNGLE then return false end
    
    CrystalColorCache = {}
    
    for _, artifactName in ipairs(ArtifactOrder) do
        local data = ArtifactData[artifactName]
        
        local leverFolder = nil
        if type(data.ChildReference) == "string" then
            leverFolder = JUNGLE:FindFirstChild(data.ChildReference)
        elseif type(data.ChildReference) == "number" then
            local children = JUNGLE:GetChildren()
            leverFolder = children[data.ChildReference]
        end
        
        if leverFolder then
            local crystal = leverFolder:FindFirstChild(data.CrystalPathSuffix)
            
            if not crystal then
                for _, child in ipairs(leverFolder:GetDescendants()) do
                    if child.Name == data.CrystalPathSuffix and child:IsA("BasePart") then
                        crystal = child
                        break
                    end
                end
            end
            
            if crystal and crystal:IsA("BasePart") then
                local color = crystal.Color
                local r = math.floor(color.R * 255)
                local g = math.floor(color.G * 255)
                local b = math.floor(color.B * 255)
                
                CrystalColorCache[artifactName] = {
                    r = r, g = g, b = b,
                    colorKey = string.format("%d,%d,%d", r, g, b)
                }
            end
        end
    end
    
    return true
end

local function GetUnlockedArtifacts()
    ScanCrystalColors()
    
    local unlockedArtifacts = {}
    
    for crystalLocation, colorData in pairs(CrystalColorCache) do
        local mappedArtifact = ColorMapping[colorData.colorKey]
        
        if mappedArtifact then
            unlockedArtifacts[mappedArtifact] = true
        else
            -- Fallback ke fungsi asli jika tidak ada di mapping
            for _, artifactName in ipairs(ArtifactOrder) do
                if OriginalIsLeverUnlocked(artifactName) then
                    unlockedArtifacts[artifactName] = true
                end
            end
        end
    end
    
    return unlockedArtifacts
end

-- FUNGSI BARU UNTUK CEK LEVER (MENGGUNAKAN DETEKSI CYCLIC SHIFT)
local function IsLeverUnlockedCyclic(artifactName)
    local unlockedArtifacts = GetUnlockedArtifacts()
