-- 4. LOGIKA AUTO FISHING (FULL MILIKMU + ANTI CONFLICT)
-- ======================================================
local FishingConfig = {
    AutoEquip = true,
    DelayChargeToReq = 0.65, 
    DelayReqToCatch = 0.35,  
}

_G.IsAutoFishing = true 
_G.PauseFishing = false -- Switch untuk menghentikan pancingan sementara

local function StartAutoFishing()
    print("🎣 Auto Fishing Started! (Background Mode)")
    DisableNativeAutoFish()

    task.spawn(function()
        while _G.IsAutoFishing do
            if _G.PauseFishing then
                task.wait(0.5) -- Jika sedang dipause, tunggu dan jangan lakukan apa-apa
            else
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    
                    -- 1. Auto Equip Tool (Pancingan)
                    if FishingConfig.AutoEquip and not lp.Character:FindFirstChildOfClass("Tool") then
                        if Remote_EquipTool then
                            pcall(function() 
                                if Remote_EquipTool:IsA("RemoteFunction") then Remote_EquipTool:InvokeServer(1) else Remote_EquipTool:FireServer(1) end
                            end)
                        end
                        task.wait(0.3)
                    end

                    -- Cek lagi apakah mendadak dipause sebelum Charge
                    if _G.PauseFishing then continue end 

                    -- 2. Mulai Charge Pancingan
                    if RF_ChargeFishingRod then FireRemote(RF_ChargeFishingRod) end
                    task.wait(FishingConfig.DelayChargeToReq)
                    
                    if _G.PauseFishing then continue end 
                    
                    -- 3. Mulai Minigame / Cast
                    if RF_RequestFishingMinigameStarted then FireRemote(RF_RequestFishingMinigameStarted) end
                    task.wait(FishingConfig.DelayReqToCatch)
                    
                    if _G.PauseFishing then continue end 
                    
                    -- 4. Selesaikan Minigame (Catch)
                    if RE_FishingCompleted then FireRemote(RE_FishingCompleted) end
                    task.wait(0.3)
                end
            end
            
            if not lp.Character then task.wait(1) end
        end
        print("🛑 Auto Fishing Stopped!")
    end)
end

