local function StartAutoFishing()
    task.spawn(function()
        while _G.IsAutoFishing do
            local holdingArtifact = false
            if lp.Character then
                local currentTool = lp.Character:FindFirstChildOfClass("Tool")
                if currentTool and (string.find(currentTool.Name, "Artifact") or string.find(currentTool.Name, "Lever")) then holdingArtifact = true end
            end

            if _G.PauseFishing or holdingArtifact then
                task.wait(0.5) 
            else
                if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                    if not lp.Character:FindFirstChildOfClass("Tool") and Remote_EquipTool then
                        pcall(function() 
                            if Remote_EquipTool:IsA("RemoteFunction") then Remote_EquipTool:InvokeServer(1) else Remote_EquipTool:FireServer(1) end
                        end)
                        task.wait(0.3)
                    end
                    if _G.PauseFishing or holdingArtifact then continue end 
                    if RF_ChargeFishingRod then FireRemote(RF_ChargeFishingRod) end
                    task.wait(0.65)
                    if _G.PauseFishing or holdingArtifact then continue end 
                    if RF_RequestFishingMinigameStarted then FireRemote(RF_RequestFishingMinigameStarted) end
                    task.wait(0.35)
                    if _G.PauseFishing or holdingArtifact then continue end 
                    if RE_FishingCompleted then FireRemote(RE_FishingCompleted) end
                    task.wait(0.3)
                end
            end
            if not lp.Character then task.wait(1) end
        end
    end)
end

local AutoSellConfig = { Enabled = true, Threshold = 100 }

