    if not index then return end
    local sleit = index:WaitForChild("sleitnick_net@0.2.0", 10)
    if not sleit then return end
    local netFolder = sleit:WaitForChild("net", 10)
    if not netFolder then return end

    local children = netFolder:GetChildren()
    local targetMap = {}
    for _, name in ipairs(TargetRemotes) do targetMap[name] = true end

    for i = 1, #children do
        local currentName = children[i].Name
        if targetMap[currentName] and i < #children then
            CachedRemotes[currentName] = children[i + 1]
        end
    end
end

