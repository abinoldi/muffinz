local function GetRodDelay(rodID)
    local rodDelays = {
        [5] = 1.5,    [169] = 0.65, [80] = 2,   [4] = 2,
        [78] = 2,     [77] = 2,     [85] = 2,   [76] = 2,
        [79] = 2,
    }
    local baseDelay = rodDelays[rodID] or 2
    return AddJitter(baseDelay, 0.15) -- Jitter terpasang
end

local function Fire(remote)
    if not remote then return end
    task.spawn(function()
        pcall(function()
            if remote:IsA("RemoteFunction") then remote:InvokeServer(1) else remote:FireServer(1) end
        end)
    end)
end

print("⚡ Fast Humanized Mode Active (0.5s - 0.7s Catch Delay)")

task.spawn(function()
    while _G.FishBotActive do
        local currentRodID = STATE.CurrentRodID or 0
        local Delay_ChargeToRequest = GetRodDelay(currentRodID)
        
        if Remotes.Charge then Fire(Remotes.Charge) end
        
        local t1 = os.clock()
        while (os.clock() - t1) < Delay_ChargeToRequest and _G.FishBotActive do RunService.Heartbeat:Wait() end
        if not _G.FishBotActive then break end

        if Remotes.Request then Fire(Remotes.Request) end

        -- Waktu reaksi minigame yang cepat tapi acak
        local humanReactionTime = GetRandomBetween(0.5, 0.7)
        local t2 = os.clock()
        while (os.clock() - t2) < humanReactionTime and _G.FishBotActive do RunService.Heartbeat:Wait() end
        if not _G.FishBotActive then break end

        if Remotes.Catch then Fire(Remotes.Catch) end
        
