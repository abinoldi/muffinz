repeat task.wait() until game:IsLoaded()

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ReplionClient = require(ReplicatedStorage.Packages.Replion).Client
local PlayerData = ReplionClient:WaitReplion("Data", 5):Get()

local hasGhostfin = false

for _, rod in pairs(PlayerData.Inventory["Fishing Rods"] or {}) do
    if tonumber(rod.Id) == 169 then
        hasGhostfin = true
        break
    end
end

if hasGhostfin then
    print("✅ HAS GHOSTFIN: YES - Executing remfarm script")
    loadstring(game:HttpGet("https://raw.githubusercontent.com/abinoldi/muffinz/refs/heads/main/remfarm"))()
else
    print("❌ HAS GHOSTFIN: NO - Executing dipsinext script")
    loadstring(game:HttpGet("https://raw.githubusercontent.com/abinoldi/muffinz/refs/heads/main/dapsinix"))()
end
