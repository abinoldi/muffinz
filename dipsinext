local function GetUnlockedArtifacts()
    local JUNGLE = workspace:FindFirstChild("JUNGLE INTERACTIONS")
    local unlocked = {}; local count = 0; if not JUNGLE then return unlocked, count end
    for _, desc in ipairs(JUNGLE:GetDescendants()) do
        if desc.Name == "Crystal" and desc:IsA("BasePart") then
            local r, g, b = desc.Color.R * 255, desc.Color.G * 255, desc.Color.B * 255
            if math.abs(r - 219) <= 4 and math.abs(g - 38) <= 4 and math.abs(b - 255) <= 4 then unlocked["Diamond Artifact"] = true; count = count + 1
            elseif math.abs(r - 255) <= 4 and math.abs(g - 248) <= 4 and math.abs(b - 49) <= 4 then unlocked["Hourglass Diamond Artifact"] = true; count = count + 1
            elseif math.abs(r - 255) <= 4 and math.abs(g - 47) <= 4 and math.abs(b - 47) <= 4 then unlocked["Arrow Artifact"] = true; count = count + 1
            elseif math.abs(r - 112) <= 4 and math.abs(g - 255) <= 4 and math.abs(b - 69) <= 4 then unlocked["Crescent Artifact"] = true; count = count + 1 end
        end
    end
    return unlocked, count
end

