end

local function UpdateGameMode()
    if not PlayerData then STATE.TargetInfo = "Loading Data..."; return end
    local data = PlayerData:Get(); if not data then return end
    STATE.TotalCoins = data.Coins or 0
    local ownedRods = GetOwnedRods(data.Inventory or {})
    STATE.HasAstralRod = table.find(ownedRods, 5) ~= nil
    local hasGhostfin = table.find(ownedRods, 169) ~= nil

    if hasGhostfin then STATE.Mode = "Farm Enchant"; STATE.TargetInfo = "Farming Ghostfin"; STATE.NextLocation = "Enchant Room"; return end
    local dsMode, dsLoc, dsProg = CheckDeepSeaQuest(data, STATE.HasAstralRod)
    if dsMode == "DeepSea" then
        STATE.Mode = "DeepSea"; STATE.TargetInfo = dsProg; STATE.NextLocation = dsLoc
        if not STATE.HasAstralRod then
            for _, rod in ipairs(ShopRods) do
                if not table.find(ownedRods, rod.ID) and STATE.TotalCoins >= rod.Price then
                    if RF_PurchaseFishingRod then pcall(function() RF_PurchaseFishingRod:InvokeServer(rod.ID) end) end; break
                end
            end
        end
        return
    end

    if not STATE.HasAstralRod then
        local nextRod = nil
        for _, rod in ipairs(ShopRods) do if not table.find(ownedRods, rod.ID) then nextRod = rod; break end end
        if nextRod then
            STATE.Mode = "FarmNextRod"; STATE.TargetInfo = "Farming untuk: " .. nextRod.Name
            if STATE.TotalCoins >= nextRod.Price and RF_PurchaseFishingRod then pcall(function() RF_PurchaseFishingRod:InvokeServer(nextRod.ID) end) end
            local bestVal = 0; for _, oid in ipairs(ownedRods) do for _, sRod in ipairs(ShopRods) do if sRod.ID == oid and sRod.Price > bestVal then bestVal = sRod.Price end end end
            STATE.NextLocation = bestVal >= 50000 and "Treasure Room" or "Volcano"
            return
        end
    end

    if STATE.HasAstralRod and not hasGhostfin then STATE.Mode = "Farm Ghostfin"; STATE.TargetInfo = "Farming Ghostfin"; STATE.NextLocation = "Treasure Room"; return end
    STATE.Mode = "Finished"; STATE.TargetInfo = "Semua Syarat Fase 1 Terpenuhi!"; _G.CurrentScriptPhase = 2
end

