local function EquipRod(nameID)
    if not PlayerDataReplion then return end
    local inv = PlayerDataReplion:GetExpect("Inventory")
    local rods = inv["Fishing Rods"] or {}
    local targetRod = nil
    
    for _, r in pairs(rods) do
        if nameID == "Best" then
            local bestPrice = -1
            for _, s in ipairs(ShopRods) do
                if tonumber(r.Id) == s.ID and s.Price > bestPrice then 
                    targetRod = r
                    bestPrice = s.Price
                    STATE.CurrentRod = s.Name
                    STATE.CurrentRodID = s.ID 
                end
            end
        else
            if tonumber(r.Id) == nameID then 
                targetRod = r
                STATE.CurrentRodID = tonumber(r.Id)
                break 
            end
        end
    end

    if nameID == "Best" and not targetRod then
        for _, r in pairs(rods) do
            targetRod = r
            STATE.CurrentRod = "Basic/Unknown"
            STATE.CurrentRodID = tonumber(r.Id) or 0
            break
        end
    end

    if targetRod then
        pcall(function()
            if RE_EquipItem then RE_EquipItem:FireServer(targetRod.UUID, "Fishing Rods") end
            task.wait(0.2)
            if RE_EquipToolFromHotbar then RE_EquipToolFromHotbar:FireServer(1) end
         end)
    end
end

