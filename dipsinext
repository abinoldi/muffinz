local function DisableAudio()
    local SoundService = game:GetService("SoundService")
    RunService.RenderStepped:Connect(function() SoundService.Volume = 0 end)
    local function MuteSound(instance)
        if instance:IsA("Sound") then
            instance.Volume = 0
            instance.Looped = false
            if instance.Playing then instance:Stop() end
        end
    end
    for _, v in pairs(game:GetDescendants()) do pcall(MuteSound, v) end
    game.DescendantAdded:Connect(function(v) pcall(MuteSound, v) end)
end

