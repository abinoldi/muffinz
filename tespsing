-- ===============================
-- 1. UTILITY: STABLE JITTER & RANDOMIZER
-- ===============================
local rng = Random.new()

local function GetRandomBetween(min, max)
    return rng:NextNumber(min, max)
end

local function AddJitter(baseValue, variance)
    return baseValue + GetRandomBetween(-variance, variance)
end

