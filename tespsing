-- FISHING BOT: AUTO START - PAYLOAD BYPASS MODE
-- ==============================================================================
local Remotes = {
    Charge  = GetRemote("RF/ChargeFishingRod"),
    Request = GetRemote("RF/RequestFishingMinigameStarted"),
    Catch   = GetRemote("RF/CatchFishCompleted")
}

_G.FishBotActive = true

local function GetRodDelay(rodID)
    local rodDelays = { [5]=1.5, [169]=0.65, [80]=2, [4]=2, [78]=2, [77]=2, [85]=2, [76]=2, [79]=2 }
    return AddJitter(rodDelays[rodID] or 2, 0.05) 
end

print("⚡ Payload Bypass v1.2 Active (Ping Sim + Safe Vector)")

task.spawn(function()
    while _G.FishBotActive do
        local Delay_ChargeToRequest = GetRodDelay(CURRENT_ROD_ID)
        
        -- 1. MENGIRIM TIMESTAMP DENGAN SIMULASI PING (LAG JARINGAN)
        if Remotes.Charge then 
            task.spawn(function()
                pcall(function()
                    -- Mensimulasikan delay internet (ping) sebesar 20ms hingga 80ms ke masa lalu
                    local simulatedPing = GetRandomBetween(0.02, 0.08)
                    local safeTimestamp = workspace:GetServerTimeNow() - simulatedPing
                    Remotes.Charge:InvokeServer(safeTimestamp)
                end)
            end)
        end
        
        local t1 = os.clock()
        while (os.clock() - t1) < Delay_ChargeToRequest and _G.FishBotActive do RunService.Heartbeat:Wait() end
        if not _G.FishBotActive then break end

        -- 2. MENGIRIM KOORDINAT DENGAN SAFE CLAMPING (Mencegah Vector Mismatch)
        if Remotes.Request then 
            task.spawn(function()
                pcall(function()
                    -- Arah hadap X/Z bisa diacak agak lebar (+/- 1.5 derajat)
                    local arg1 = AddJitter(-139.630452165, 1.5)
                    
                    -- LookVector (Y-Axis) diacak sangat kecil (+/- 0.002) dan DIBATASI maksimal 1.0 agar tidak terdeteksi bot
                    local rawArg2 = AddJitter(0.99647927980797, 0.002)
                    local arg2 = math.clamp(rawArg2, -1, 1) 
                    
                    Remotes.Request:InvokeServer(arg1, arg2)
                end)
            end)
        end

        local humanReactionTime = GetRandomBetween(0.05, 0.09)
        local t2 = os.clock()
        while (os.clock() - t2) < humanReactionTime and _G.FishBotActive do RunService.Heartbeat:Wait() end
        if not _G.FishBotActive then break end

        -- 3. CATCH FISH
        if Remotes.Catch then 
            task.spawn(function()
                pcall(function()
                    Remotes.Catch:InvokeServer() 
                end)
            end)
        end
        
        task.wait(GetRandomBetween(0.05, 0.12))
    end
end)

-- Notify Stats (Penghitung Ikan)
local function CalcStats() local mins = (os.time()-STATE.StartTime)/60; STATE.FishPerMinute = mins>0 and STATE.FishCount/mins or 0 end
local function FormatTime(s) return string.format("%02dh %02dm %02ds", math.floor(s/3600), math.floor((s%3600)/60), s%60) end

if RE_ObtainedNewFishNotification then
    RE_ObtainedNewFishNotification.OnClientEvent:Connect(function() 
        STATE.FishCount=STATE.FishCount+1; CalcStats()
    end)
end

