local function CheckDeepSeaQuest(data, hasAstral)
    local quest = data.Quests and data.Quests.Mainline and data.Quests.Mainline["Deep Sea Quest"]
    local completed = data.Quests and data.Quests.Completed and data.Quests.Completed["Deep Sea Quest"]

    if completed then return "Done" end

    -- [FIX] Teleport ke Sisyphus hanya untuk numpang lewat agar quest aktif otomatis
    if not quest then 
        if hasAstral then
            return "DeepSea", "Sisyphus Statue", "Activating Quest..."
        else
            return "Done"
        end
    end
    
    local sObj = quest.CurrentObj or 1
    local progMap = {}
    for _,o in pairs(quest.Objectives or {}) do progMap[o.Id] = o.Progress or 0 end
  
    local actObj = sObj
    if actObj==1 and (progMap[1] or 0)>=300 then actObj=2 end
    if actObj==2 and (progMap[2] or 0)>=3 then actObj=3 end
    if actObj==3 and (progMap[3] or 0)>=1 then actObj=4 end
    if actObj==4 and (progMap[4] or 0)>=1000000 then return "Done" end 
    
    if actObj==1 then return "DeepSea", "Treasure Room", (progMap[1] or 0).."/300 Fish"
    elseif actObj==2 then return "DeepSea", "Sisyphus Statue", (progMap[2] or 0).."/3 Mythic"
    elseif actObj==3 then return "DeepSea", "Sisyphus Statue", (progMap[3] or 0).."/1 Secret"
    elseif actObj==4 then return "DeepSea", (table.find(GetOwnedRods(data.Inventory),5) and "Sacred Temple" or "Esoteric Island"), (progMap[4] or 0).."/1M Coins"
    end
    return "Done"
end

local function UpdateGameMode()
    if not PlayerDataReplion then return end
    local data = PlayerDataReplion:Get()
    if not data then return end
    
    STATE.TotalCoins = data.Coins or 0
    local inv = data.Inventory or {}
    local ownedRods = GetOwnedRods(inv)

    STATE.HasAstralRod = table.find(ownedRods, 5) ~= nil
    local hasGhostfin = table.find(ownedRods, 169) ~= nil

    -- 1. PRIORITAS UTAMA: GHOSTFIN (ENCHANT ROOM)
    if hasGhostfin then
        STATE.Mode = "Farm Enchant"
        STATE.TargetInfo = "Farming (Ghostfin)"
        STATE.NextLocation = "Enchant Room"
        return
    end

    -- 2. CEK QUEST DEEP SEA 
    local dsMode, dsLoc, dsProg = CheckDeepSeaQuest(data, STATE.HasAstralRod)
    if dsMode == "DeepSea" then
        STATE.Mode = "DeepSea"
        STATE.TargetInfo = dsProg
        STATE.NextLocation = dsLoc
        
        if not STATE.HasAstralRod then
            for _, rod in ipairs(ShopRods) do
                if not table.find(ownedRods, rod.ID) and STATE.TotalCoins >= rod.Price then
                    if RF_PurchaseFishingRod then pcall(function() RF_PurchaseFishingRod:InvokeServer(rod.ID) end) end
                    break
                end
            end
        end
        return
    end

    -- 3. JIKA BELUM PUNYA ASTRAL
    if not STATE.HasAstralRod then
        local nextRodToBuy = nil
        for _, rod in ipairs(ShopRods) do
            if not table.find(ownedRods, rod.ID) then nextRodToBuy = rod; break end
        end
        
        if nextRodToBuy then
            STATE.Mode = "FarmNextRod"
            local progressText
            if STATE.TotalCoins >= nextRodToBuy.Price then 
                progressText = "AUTO BUYING " .. nextRodToBuy.Name 
                if RF_PurchaseFishingRod then pcall(function() RF_PurchaseFishingRod:InvokeServer(nextRodToBuy.ID) end) end
                task.wait(0.5)  
            else 
                progressText = string.format("Farming %s: %d%%", nextRodToBuy.Name, math.floor((STATE.TotalCoins/nextRodToBuy.Price)*100)) 
            end
            
            local bestArea = "Volcano"
            local currentBestRodValue = 0
            for _, ownedId in ipairs(ownedRods) do
                for _, shopRod in ipairs(ShopRods) do
                    if shopRod.ID == ownedId and shopRod.Price > currentBestRodValue then currentBestRodValue = shopRod.Price end
                end
            end
            if currentBestRodValue >= 50000 then bestArea = "Treasure Room" else bestArea = "Volcano" end
            
            STATE.TargetInfo = progressText; STATE.NextLocation = bestArea; STATE.NextRodInfo = nextRodToBuy
            return
        else
            STATE.Mode = "FarmNextRod"; STATE.TargetInfo = "Farming Astral (Fallback)"; STATE.NextLocation = "Treasure Room"; return
        end
    end

    -- 4. JIKA ASTRAL SUDAH PUNYA, TAPI GHOSTFIN BELUM, DAN QUEST SUDAH DONE
    if STATE.HasAstralRod and not hasGhostfin then
        STATE.Mode = "Farm Ghostfin"
        STATE.TargetInfo = "Farming Ghostfin"
        STATE.NextLocation = "Treasure Room" 
        return
    end

    STATE.Mode = "Finished"; STATE.TargetInfo = "All Quests Done"; STATE.NextLocation = "Esoteric Island"
end

