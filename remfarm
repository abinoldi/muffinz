local function RunAutoTrade()
    if TradingState.IsTrading then return end
    TradingState.IsTrading = true
    TradingState.Thread = task.spawn(function()
        while MasterConfig.AutoTrade and TradingState.IsTrading do
            local targetPlayer = Services.Players:FindFirstChild(MasterConfig.TargetUsername)
            if targetPlayer and RF_InitiateTrade then
                local inv = PlayerData:GetExpect("Inventory")
                if inv then
                    local itemTraded = false
                    for _, items in pairs(inv) do
                        if itemTraded then break end
                        for _, item in ipairs(items) do
                            local name, rarity = GetFishNameAndRarity(item)
                            
                            local isSecret = (tostring(rarity):upper() == "SECRET")
                            local isRubyGem = (name == "Ruby" and GetMutation(item) == "Gemstone")
                            local isEvolvedStone = (tostring(item.Id) == "558" or string.find(string.lower(name), "evolved enchant stone"))

                            if isSecret or isRubyGem or isEvolvedStone then
                                pcall(function() RF_InitiateTrade:InvokeServer(targetPlayer.UserId, item.UUID) end)
                                itemTraded = true
                                task.wait(5)
                                break
                            end
                        end
                    end
                end
            end
            task.wait(MasterConfig.TradeDelay)
        end
        TradingState.IsTrading = false
    end)
end

