local function GetUnlockedArtifacts()
    local JUNGLE = workspace:FindFirstChild("JUNGLE INTERACTIONS")
    local unlocked = {}
    local count = 0
    if not JUNGLE then return unlocked, count end

    for _, desc in ipairs(JUNGLE:GetDescendants()) do
        if desc.Name == "Crystal" and desc:IsA("BasePart") then
            local r, g, b = desc.Color.R * 255, desc.Color.G * 255, desc.Color.B * 255
            
            if math.abs(r - 219) <= 4 and math.abs(g - 38) <= 4 and math.abs(b - 255) <= 4 then 
                unlocked["Diamond Artifact"] = true; count = count + 1
            elseif math.abs(r - 255) <= 4 and math.abs(g - 248) <= 4 and math.abs(b - 49) <= 4 then 
                unlocked["Hourglass Diamond Artifact"] = true; count = count + 1
            elseif math.abs(r - 255) <= 4 and math.abs(g - 47) <= 4 and math.abs(b - 47) <= 4 then 
                unlocked["Arrow Artifact"] = true; count = count + 1
            elseif math.abs(r - 112) <= 4 and math.abs(g - 255) <= 4 and math.abs(b - 69) <= 4 then 
                unlocked["Crescent Artifact"] = true; count = count + 1
            end
        end
    end
    return unlocked, count
end

local function HasArtifactItem(artifactName)
    if lp.Character then
        for _, v in ipairs(lp.Character:GetChildren()) do
            if v:IsA("Tool") and string.find(v.Name, artifactName) then return true end
        end
    end
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, v in ipairs(backpack:GetChildren()) do
            if v:IsA("Tool") and string.find(v.Name, artifactName) then return true end
        end
    end
    if not PlayerData then return false end
    local hasItem = false
    pcall(function()
        local inv = PlayerData:Get("Inventory")
        local targetId = ARTIFACT_IDS[artifactName]
        for _, items in pairs(inv) do
            for _, item in ipairs(items) do
                if tonumber(item.Id) == targetId then hasItem = true return end
            end
        end
    end)
    return hasItem
end

local placementAttempts = {} 

local function DoAutoLever()
    _G.CurrentPhase = "Auto Lever (1/2)"
    local globalRechecks = 0

    while _G.IsAutoFishing do
        local unlockedArtifacts, unlockedCount = GetUnlockedArtifacts()
        _G.LeverProgress = tostring(unlockedCount) .. "/4"
        
        local allDoneOrSkipped = true
        local artifactToProcess = nil
        
        for _, artifactName in ipairs(ArtifactOrder) do
            if not unlockedArtifacts[artifactName] then
                if (placementAttempts[artifactName] or 0) < 3 then
                    allDoneOrSkipped = false
                    if not artifactToProcess then artifactToProcess = artifactName end
                end
            end
        end

        if allDoneOrSkipped then
            _G.CurrentAction = "Memverifikasi Pemasangan Lever (Re-check)..."
            task.wait(3) 
            
            local recheckArtifacts, recheckCount = GetUnlockedArtifacts()
            if recheckCount >= 4 then
                _G.CurrentAction = "Semua Lever Selesai & Valid!"
                break
            else
                if globalRechecks < 3 then
                    _G.CurrentAction = "Terdeteksi Miss! Mengulang Pemasangan..."
                    globalRechecks = globalRechecks + 1
                    for _, artifactName in ipairs(ArtifactOrder) do
                        if not recheckArtifacts[artifactName] then
                            placementAttempts[artifactName] = 0 
                        end
                    end
                    task.wait(2)
                else
                    _G.CurrentAction = "Lever Selesai (Limit Recheck Maksimal!)"
                    break
                end
            end
        elseif artifactToProcess then
            local artData = ArtifactData[artifactToProcess]
            local char = lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")

            if HasArtifactItem(artifactToProcess) then
                local currentAttempts = (placementAttempts[artifactToProcess] or 0) + 1
                _G.CurrentAction = "Memasang: " .. artifactToProcess .. " (" .. currentAttempts .. "/3)"
                _G.PauseFishing = true 
                task.wait(0.5)
                
                if hrp and (hrp.Position - artData.TargetPos.Pos).Magnitude > 5 then
                    TeleportToLookAt(artData.TargetPos.Pos, artData.TargetPos.Look)
                    task.wait(1.5) 
                end

                if hrp then hrp.Anchored = true end
                
                local backpack = lp:FindFirstChild("Backpack")
                if hum and backpack then
                    for _, tool in ipairs(backpack:GetChildren()) do
                        if tool:IsA("Tool") and string.find(tool.Name, artifactToProcess) then
                            hum:EquipTool(tool)
                            break
                        end
                    end
                end
                
                task.wait(1.5) 
                if RE_PlaceLeverItem then 
                    FireRemote(RE_PlaceLeverItem, artifactToProcess) 
                    placementAttempts[artifactToProcess] = currentAttempts 
                end
                task.wait(2.5) 
                if hrp then hrp.Anchored = false end
            else
                _G.CurrentAction = "Mencari: " .. artifactToProcess
                _G.PauseFishing = false 
                if hrp and (hrp.Position - artData.FishingPos.Pos).Magnitude > 5 then
                    TeleportToLookAt(artData.FishingPos.Pos, artData.FishingPos.Look)
                    task.wait(1.5)
                end
                task.wait(1) 
            end
        end
        task.wait(0.1)
    end
end

