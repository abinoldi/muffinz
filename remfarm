local function InitializeRemotes()
    local netFolder = Services.ReplicatedStorage:FindFirstChild("Packages")
    if netFolder then
        netFolder = netFolder:FindFirstChild("_Index")
        if netFolder then
            netFolder = netFolder:FindFirstChild("sleitnick_net@0.2.0")
            if netFolder then
                netFolder = netFolder:FindFirstChild("net")
                if netFolder then
                    local children = netFolder:GetChildren()
                    local targetMap = {}
                    for _, name in ipairs(TargetRemotes) do targetMap[name] = true end
                    for i = 1, #children do
                        if targetMap[children[i].Name] and i < #children then
                            CachedRemotes[children[i].Name] = children[i + 1]
                        end
                    end
                end
            end
        end
    end
end

