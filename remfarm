local function IsFishPlaced(itemName)
    local ruinFolder = workspace:FindFirstChild("RUIN INTERACTIONS")
    local platesFolder = ruinFolder and ruinFolder:FindFirstChild("PressurePlates")
    if not platesFolder then return false end
    local rarity = FishToRarity[itemName]
    if not rarity then return false end
    local plateModel = platesFolder:FindFirstChild(rarity)
    if plateModel then
        local movePart = plateModel:FindFirstChild("MOVE_PART")
        local stepPlate = movePart and movePart:FindFirstChild("StepPlate")
        if stepPlate and stepPlate.Position.Y < -541.1 then return true end
    end
    return false
end

local function StartAutoFishingLVCB()
    task.spawn(function()
        while _G.IsAutoFishing do
            local holdingArtifact = false
            if lp.Character then
                local currentTool = lp.Character:FindFirstChildOfClass("Tool")
                if currentTool and (string.find(currentTool.Name, "Artifact") or string.find(currentTool.Name, "Lever")) then holdingArtifact = true end
